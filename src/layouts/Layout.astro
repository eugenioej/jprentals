---
import '@/styles/global.css';
import type { Locale } from '@/i18n/utils';
import { t, getAlternateUrl } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const alternateLocale: Locale = locale === 'es' ? 'en' : 'es';
const alternateUrl = getAlternateUrl(Astro.url, alternateLocale);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

// Schema.org LocalBusiness structured data
const schemaData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "JP Rentals",
  "description": i.meta.description,
  "url": "https://jprentals.mx",
  "telephone": "+528116007864",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Monterrey",
    "addressRegion": "Nuevo León",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "25.6866",
    "longitude": "-100.3161"
  },
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": "25.6866",
      "longitude": "-100.3161"
    },
    "geoRadius": "40000"
  },
  "serviceType": [
    "Industrial Crane Rental",
    "Heavy Machinery Transport",
    "Industrial Rigging Services"
  ],
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "07:00",
    "closes": "19:00"
  },
  "sameAs": []
};

// FAQPage schema
const faqSchema = locale === 'es' ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué capacidades tienen las grúas de JP Rentals?",
      "acceptedAnswer": { "@type": "Answer", "text": "Contamos con grúas industriales de 8, 15, 18, 22 y 50 toneladas, además de grúa articulada de 8 toneladas. Toda la flota está disponible para renta en Monterrey y área metropolitana." }
    },
    {
      "@type": "Question",
      "name": "¿En qué zonas de Monterrey operan?",
      "acceptedAnswer": { "@type": "Answer", "text": "Operamos en toda el área metropolitana de Monterrey: Monterrey, San Pedro, Santa Catarina, Guadalupe, Apodaca, General Escobedo, San Nicolás y zonas industriales aledañas." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo solicito una cotización de grúa industrial?",
      "acceptedAnswer": { "@type": "Answer", "text": "La forma más rápida es por WhatsApp al +52 81 1600-7864. Cuéntanos el peso de la carga, la maniobra que necesitas y la ubicación, y te respondemos con precio y disponibilidad." }
    },
    {
      "@type": "Question",
      "name": "¿Ofrecen renta mensual de grúas para plantas industriales?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Tenemos renta diaria, semanal y mensual de grúas industriales. La grúa se posiciona directamente en tu planta para operaciones continuas o proyectos de montaje." }
    },
    {
      "@type": "Question",
      "name": "¿JP Rentals hace flete de maquinaria pesada?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Contamos con tráiler Howo de 30 toneladas con grúa articulada incluida para carga y descarga puerta a puerta, y plataforma extensible para cargas de hasta 60 metros de longitud." }
    },
    {
      "@type": "Question",
      "name": "¿Quién es JP Rentals?",
      "acceptedAnswer": { "@type": "Answer", "text": "JP Rentals es parte de Grupo NASA, grupo industrial con más de 30 años en la industria del acero y la construcción en Monterrey. También somos parte del mismo grupo que Nasacero y Nacional de Anclas." }
    }
  ]
} : {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What crane capacities does JP Rentals offer?",
      "acceptedAnswer": { "@type": "Answer", "text": "We operate industrial cranes from 8 to 50 tons: 8T articulated, 15T, 18T, 22T, and 50T conventional cranes. All available for rental in Monterrey and the metropolitan area." }
    },
    {
      "@type": "Question",
      "name": "What areas do you serve in Monterrey?",
      "acceptedAnswer": { "@type": "Answer", "text": "We cover the entire Monterrey metro area including San Pedro, Santa Catarina, Guadalupe, Apodaca, General Escobedo, San Nicolás, and surrounding industrial zones." }
    },
    {
      "@type": "Question",
      "name": "How do I request a crane rental quote?",
      "acceptedAnswer": { "@type": "Answer", "text": "The fastest way is via WhatsApp at +52 81 1600-7864. Tell us the load weight, the maneuver needed, and the location — we'll respond with pricing and availability." }
    },
    {
      "@type": "Question",
      "name": "Do you offer monthly crane rental for industrial plants?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer daily, weekly, and monthly crane rental. The crane is positioned directly at your plant for continuous operations or assembly projects." }
    },
    {
      "@type": "Question",
      "name": "Do you transport heavy machinery?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We have a 30-ton Howo trailer with an articulated crane for door-to-door loading and unloading, plus an extendable platform for loads up to 60 meters long." }
    }
  ]
};

// Service schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Industrial Crane Rental and Machinery Transport",
  "provider": {
    "@type": "LocalBusiness",
    "name": "JP Rentals"
  },
  "areaServed": {
    "@type": "City",
    "name": "Monterrey"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Industrial Services",
    "itemListElement": i.services.items.map((svc, idx) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": svc.title,
        "description": svc.description
      }
    }))
  }
};
---

<!DOCTYPE html>
<html lang={locale === 'es' ? 'es-MX' : 'en-US'} dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Primary Meta Tags -->
  <title>{i.meta.title}</title>
  <meta name="description" content={i.meta.description} />
  <meta name="keywords" content={i.meta.keywords} />
  <meta name="robots" content="index, follow" />

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href={canonicalUrl.href} />
  <link rel="alternate" hreflang="es" href={new URL(locale === 'es' ? Astro.url.pathname : getAlternateUrl(Astro.url, 'es'), Astro.site).href} />
  <link rel="alternate" hreflang="en" href={new URL(locale === 'en' ? Astro.url.pathname : getAlternateUrl(Astro.url, 'en'), Astro.site).href} />
  <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={i.meta.title} />
  <meta property="og:description" content={i.meta.description} />
  <meta property="og:url" content={canonicalUrl.href} />
  <meta property="og:site_name" content="JP Rentals" />
  <meta property="og:locale" content={locale === 'es' ? 'es_MX' : 'en_US'} />
  <meta property="og:locale:alternate" content={locale === 'es' ? 'en_US' : 'es_MX'} />
  <meta property="og:image" content={new URL('/images/og-image.jpg', Astro.site).href} />
  <meta property="og:image:type" content="image/jpeg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="JP Rentals — Flota de grúas industriales en Monterrey, México" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={i.meta.title} />
  <meta name="twitter:description" content={i.meta.description} />
  <meta name="twitter:image" content={new URL('/images/og-image.jpg', Astro.site).href} />
  <meta name="twitter:image:alt" content="JP Rentals — Grúas industriales y transporte de maquinaria en Monterrey" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

  <!-- Schema.org Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</head>
<body class="overflow-x-hidden">
  <slot />

  <!-- Scroll animation observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.fade-in').forEach((el) => {
      observer.observe(el);
    });
  </script>
</body>
</html>
