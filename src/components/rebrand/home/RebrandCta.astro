---
import type { RebrandHomeCopy } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
}

const { copy } = Astro.props;
const d = copy.cta;
---

<section
  id="contacto"
  class="scroll-mt-24 border-t border-jpr2-navy/10 bg-jpr2-crema py-14 md:py-20"
  aria-labelledby="contacto-title"
>
  <div class="container max-w-5xl">
    <header class="jpr2-fade mb-10 max-w-2xl text-center md:mx-auto md:mb-12 md:text-center">
      <h2
        id="contacto-title"
        class="text-2xl font-extrabold tracking-tight text-jpr2-navy md:text-3xl"
      >
        {d.title}
      </h2>
      {d.intro && <p class="mt-2 text-sm leading-relaxed text-jpr2-ink/70 md:text-base">{d.intro}</p>}
    </header>

    <div
      class="jpr2-fade flex flex-col gap-0 overflow-hidden rounded-2xl border border-jpr2-navy/10 bg-white shadow-[0_4px_24px_rgba(10,15,30,0.07)] sm:p-0 md:grid md:grid-cols-3 md:divide-x md:divide-jpr2-navy/10"
    >
      <div
        class="px-5 py-8 sm:px-8 sm:py-10"
      >
        <h3
          class="text-[0.7rem] font-extrabold uppercase tracking-[0.2em] text-jpr2-coral"
        >
          {d.labels.phone}
        </h3>
        <ul class="mt-6 space-y-6" role="list">
          {
            d.phones.map((p) => (
              <li>
                <p class="text-xs font-medium text-jpr2-muted uppercase tracking-wide">{p.name}</p>
                <a
                  class="mt-1 inline-block text-base font-semibold text-jpr2-navy transition-colors hover:text-jpr2-coral"
                  href={p.href}
                >
                  {p.display}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="border-t border-jpr2-navy/10 px-5 py-8 sm:px-8 sm:py-10 md:border-t-0"
      >
        <h3
          class="text-[0.7rem] font-extrabold uppercase tracking-[0.2em] text-jpr2-coral"
        >
          {d.labels.email}
        </h3>
        <ul class="mt-6 space-y-3" role="list">
          {
            d.emails.map((e) => (
              <li>
                <a
                  class="break-words text-sm font-medium text-jpr2-navy underline-offset-2 hover:underline"
                  href={`mailto:${e.address}`}
                >
                  {e.address}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="border-t border-jpr2-navy/10 bg-jpr2-crema/30 px-5 py-8 sm:px-8 sm:py-10 md:border-t-0"
      >
        <h3
          class="text-[0.7rem] font-extrabold uppercase tracking-[0.2em] text-jpr2-coral"
        >
          {d.labels.office}
        </h3>
        <address class="not-italic">
          {
            d.addressLines.map((line) => (
              <p class="mt-1 first:mt-4 text-sm leading-relaxed text-jpr2-ink/90">{line}</p>
            ))
          }
        </address>
        <a
          class="mt-5 inline-flex text-xs font-semibold text-jpr2-navy/80 hover:text-jpr2-coral"
          href="https://www.google.com/maps/search/?api=1&query=Anastacio%20Bustamante%201030%2C%20Bella%20Vista%2C%2064410%20Monterrey"
          rel="noopener"
          target="_blank"
        >
          {d.mapLink}
        </a>
      </div>
    </div>
  </div>
</section>
