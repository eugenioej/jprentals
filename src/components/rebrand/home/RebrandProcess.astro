---
import type { RebrandHomeCopy } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
}

const { copy } = Astro.props;
const p = copy.process;

function encodeUrlPath(url: string): string {
  return `/${url
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}
---

<section
  id="proceso"
  class="scroll-mt-24 border-b border-jpr2-navy/10 bg-jpr2-crema py-16 md:py-24"
  aria-labelledby="proceso-title"
>
  <div class="container max-w-6xl">
    <p class="jpr2-eyebrow jpr2-fade">{p.eyebrow}</p>
    <h2 id="proceso-title" class="jpr2-fade mt-3 text-2xl font-extrabold text-jpr2-navy md:text-3xl">
      {p.title}
    </h2>
    <p class="jpr2-fade mt-3 max-w-3xl text-base leading-relaxed text-jpr2-ink/85">
      {p.intro}
    </p>

    <nav class="jpr2-fade mt-8 flex flex-wrap gap-2" aria-label={p.stepsNavAria}>
      {
        p.steps.map((s) => (
          <a
            href={`#proceso-${s.id}`}
            class="rounded-full border border-jpr2-navy/12 bg-white px-3 py-1.5 text-xs font-semibold text-jpr2-navy shadow-sm transition-colors hover:border-jpr2-coral/40 hover:text-jpr2-coral md:text-sm"
          >
            <span class="font-mono font-bold text-jpr2-coral">{s.id}</span>
            <span class="ml-1.5">{s.shortTitle}</span>
          </a>
        ))
      }
    </nav>

    <div class="mt-14 flex flex-col gap-[40px] md:mt-16">
      {
        p.steps.map((step, i) => (
          <article
            id={`proceso-${step.id}`}
            class="jpr2-surface scroll-mt-28 overflow-hidden p-5 sm:p-6 md:p-7"
          >
            <div class="grid grid-cols-1 gap-6 md:grid-cols-12 md:gap-8 md:items-start">
              <div class:list={[i % 2 === 0 ? 'md:order-1' : 'md:order-2', 'md:col-span-5']}>
                <div class="aspect-[4/3] overflow-hidden rounded-xl border border-jpr2-navy/10 bg-jpr2-mist/40">
                  <img
                    src={encodeUrlPath(step.image)}
                    alt={step.imageAlt}
                    class="h-full w-full object-cover"
                    width={960}
                    height={720}
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
              <div class:list={[i % 2 === 0 ? 'md:order-2' : 'md:order-1', 'md:col-span-7']}>
                <p class="font-mono text-xs font-bold tracking-[0.18em] text-jpr2-coral">
                  {p.stepLabel.replace('{n}', step.id)}
                </p>
                <h3 class="mt-2 text-xl font-extrabold text-jpr2-navy md:text-2xl">{step.title}</h3>
                <p class="mt-1 text-base font-semibold text-jpr2-ink">{step.tagline}</p>
                <p class="mt-4 text-base leading-relaxed text-jpr2-ink/85">{step.body}</p>
                <ul class="mt-6 space-y-4" role="list">
                  {
                    step.bullets.map((b) => (
                      <li class="border-l-2 border-jpr2-coral/45 pl-4">
                        <strong class="block text-base font-bold text-jpr2-navy">{b.title}</strong>
                        <span class="mt-0.5 block text-base leading-relaxed text-jpr2-ink/80">{b.text}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
