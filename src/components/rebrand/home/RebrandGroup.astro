---
import type { RebrandHomeCopy } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
}

const { copy } = Astro.props;
const g = copy.group;

function encodeUrlPath(p: string): string {
  return `/${p
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}

const nacionalLogoSrc = encodeUrlPath('/images/home-rebrand/Logo Nacional de Anclas.webp');
const nasaceroLogoSrc = encodeUrlPath('/images/home-rebrand/Nasacero-Logo.webp');
---

<section
  id="grupo"
  class="relative overflow-hidden border-b border-jpr2-navy/10 bg-jpr2-crema py-14 md:py-18"
  aria-labelledby="grupo-title"
>
  <div
    class="absolute inset-0 bg-[url('/images/grupo-nasa.webp')] bg-cover bg-center opacity-20"
    aria-hidden="true"
  />
  <div class="absolute inset-0 bg-jpr2-crema/85" aria-hidden="true" />

  <div class="container relative z-10 max-w-6xl">
    <div
      class="jpr2-fade relative overflow-hidden rounded-2xl border border-jpr2-navy/10 bg-white px-6 py-10 text-center shadow-[0_16px_48px_rgba(31,45,78,0.1)] md:px-10 md:py-14"
    >
      <h2 id="grupo-title" class="mx-auto max-w-3xl text-2xl font-extrabold text-jpr2-navy md:text-3xl">
        {g.title}
      </h2>
      <p class="mx-auto mt-3 max-w-3xl text-base leading-relaxed text-jpr2-ink/85">
        {g.intro}
      </p>

      <div class="mx-auto mt-7 grid max-w-4xl gap-4 md:grid-cols-2">
        <a
          href="https://nacionaldeanclas.com"
          target="_blank"
          rel="noopener"
          class="flex flex-col items-center gap-4 rounded-xl border border-jpr2-navy/12 bg-white p-5 text-jpr2-ink transition-colors hover:border-jpr2-navy/20 hover:bg-jpr2-crema"
        >
          <div class="flex h-20 w-full max-w-[14rem] shrink-0 items-center justify-center sm:h-24">
            <img
              src={nacionalLogoSrc}
              alt=""
              width={160}
              height={80}
              class="max-h-16 w-full max-w-full object-contain object-center sm:max-h-20"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="w-full min-w-0 text-left">
            <h3 class="text-base font-bold text-jpr2-navy">{g.nacionalTitle}</h3>
            <p class="mt-1 text-xs text-jpr2-muted">{g.nacionalUrl}</p>
            <p class="mt-3 text-base leading-relaxed text-jpr2-ink/90">{g.nacionalBody}</p>
          </div>
        </a>

        <a
          href="https://nasacero.com"
          target="_blank"
          rel="noopener"
          class="flex flex-col items-center gap-4 rounded-xl border border-jpr2-navy/12 bg-white p-5 text-jpr2-ink transition-colors hover:border-jpr2-navy/20 hover:bg-jpr2-crema"
        >
          <div class="flex h-20 w-full max-w-[14rem] shrink-0 items-center justify-center sm:h-24">
            <img
              src={nasaceroLogoSrc}
              alt=""
              width={160}
              height={80}
              class="max-h-16 w-full max-w-full object-contain object-center sm:max-h-20"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="w-full min-w-0 text-left">
            <h3 class="text-base font-bold text-jpr2-navy">{g.nasaceroTitle}</h3>
            <p class="mt-1 text-xs text-jpr2-muted">{g.nasaceroUrl}</p>
            <p class="mt-3 text-base leading-relaxed text-jpr2-ink/90">{g.nasaceroBody}</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
