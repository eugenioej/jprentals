---
import type { RebrandHomeCopy } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
}

const { copy } = Astro.props;
---

<section
  class="border-b border-jpr2-navy/10 bg-jpr2-crema -mt-px shadow-[0_1px_0_0_rgba(31,45,78,0.08)]"
  aria-label="Cifras"
>
  <div class="container max-w-6xl py-10 md:py-14">
    <div class="grid grid-cols-1 gap-12 text-center sm:grid-cols-3 sm:gap-10 sm:text-left">
      {
        copy.stats.items.map((s, i) => (
          <div class="jpr2-fade" style={`transition-delay: ${i * 60}ms`}>
            <div class="text-4xl font-black tabular-nums tracking-tight text-jpr2-coral sm:text-5xl md:text-6xl">
              {s.value}
            </div>
            <p class="mt-2.5 text-sm font-semibold leading-snug text-jpr2-ink/75 md:text-base">
              {s.label}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
