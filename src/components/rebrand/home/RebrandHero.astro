---
import type { RebrandHomeCopy } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
}

function encodeUrlPath(p: string): string {
  return `/${p.split('/').filter(Boolean).map(encodeURIComponent).join('/')}`;
}

const { copy } = Astro.props;
// Selección visual de casos para fondo animado del hero.
const heroBgImages = [
  '/images/home-rebrand/casos/coca-cola/IMG20251005080401.webp',
  '/images/home-rebrand/casos/kandelium/IMG20260116115504.webp',
  '/images/home-rebrand/casos/kontar-ii/IMG20250716111914.webp',
  '/images/home-rebrand/casos/mod-4/IMG20240731173330.webp',
  '/images/home-rebrand/casos/daye-hoffsan/IMG_20230926_145238.webp',
  '/images/home-rebrand/casos/motomex-cedis-1/IMG_20221213_073612.webp',
];
const heroBg = heroBgImages.map(encodeUrlPath);
---

<section
  class="rebrand-hero-mesh jpr2-hero-frame relative flex min-h-0 flex-col overflow-hidden"
  aria-labelledby="rebrand-hero-h1"
>
  <div
    class="pointer-events-none absolute inset-0 z-[1] opacity-[0.04]"
    style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%231f2d4e\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
  />

  <div
    class="jpr2-hero-grid relative z-10 flex min-h-0 w-full min-w-0 flex-1 flex-col content-center items-stretch justify-center max-lg:gap-8 max-lg:py-10 sm:max-lg:py-12 lg:flex-row lg:items-stretch"
  >
    <div
      class="jpr2-hero-text order-1 flex w-full min-w-0 max-w-2xl flex-col justify-center px-4 text-left sm:px-6 lg:max-w-none lg:w-1/2 lg:flex-[0_0_50%] lg:shrink-0 lg:py-12 lg:pl-[max(1.5rem,calc((100vw-72rem)/2+1.5rem))] lg:pr-8 lg:max-xl:pr-10 xl:pr-12"
    >
      <p class="jpr2-eyebrow jpr2-fade mb-4 sm:mb-5">
        {copy.hero.eyebrow}
      </p>
      <h1
        id="rebrand-hero-h1"
        class="jpr2-fade text-3xl sm:text-4xl md:text-[2.4rem] lg:text-4xl xl:text-5xl font-extrabold leading-[1.12] text-jpr2-navy"
        style="animation-delay: 0.05s"
      >
        {copy.hero.headline}
      </h1>
      <p
        class="jpr2-fade mt-5 sm:mt-6 text-base text-jpr2-ink/80 max-w-xl leading-relaxed md:text-lg"
      >
        {copy.hero.sub}
      </p>
    </div>

    <div
      class="jpr2-hero-image-shell order-2 relative w-full min-w-0 min-h-[18rem] flex-[0_0_auto] overflow-hidden border border-jpr2-navy/10 border-r-0 bg-white sm:min-h-[20rem] sm:mx-4 lg:mx-0 lg:min-h-0 lg:w-1/2 lg:max-w-[50%] lg:shrink-0 lg:flex-[0_0_50%] lg:h-full"
    >
      <div
        class="jpr2-hero-bg absolute inset-0 h-full w-full min-h-full min-w-full"
        aria-hidden="true"
      >
        {
          heroBg.map((src, idx) => (
            <img
              src={idx === 0 ? src : 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw=='}
              alt=""
              class="jpr2-hero-bg__slide"
              data-src={idx === 0 ? undefined : src}
              loading={idx === 0 ? 'eager' : 'lazy'}
              fetchpriority={idx === 0 ? 'high' : 'low'}
              decoding={idx === 0 ? 'sync' : 'async'}
              style={`animation-delay: ${idx * 6}s;`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>


<script is:inline>
  (() => {
    const hydrateHeroSlides = () => {
      document.querySelectorAll('.jpr2-hero-bg__slide[data-src]').forEach((img) => {
        const src = img.getAttribute('data-src');
        if (!src) return;
        img.setAttribute('src', src);
        img.removeAttribute('data-src');
      });
    };

    const schedule = () => {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(hydrateHeroSlides, { timeout: 1800 });
      } else {
        setTimeout(hydrateHeroSlides, 1200);
      }
    };

    if (document.readyState === 'complete') schedule();
    else window.addEventListener('load', schedule, { once: true });
  })();
</script>
