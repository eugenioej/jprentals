---
import { rebrandServicePath, type RebrandHomeCopy, type RebrandLang } from '@/i18n/rebrand/home';
import { getRebrandServiceBySlug } from '@/i18n/rebrand/services';

interface Props {
  copy: RebrandHomeCopy;
  lang: RebrandLang;
}

const { copy, lang } = Astro.props;
---

<section
  id="servicios"
  class="border-b border-jpr2-navy/10 bg-jpr2-crema py-16 md:py-24"
  aria-labelledby="servicios-title"
>
  <div class="container max-w-6xl">
    <h2 id="servicios-title" class="jpr2-fade text-2xl font-extrabold text-jpr2-navy md:text-3xl">
      {copy.offer.title}
    </h2>
    {copy.offer.subtitle && (
      <p class="jpr2-fade mt-2 max-w-2xl text-sm text-jpr2-ink/75 md:text-base">
        {copy.offer.subtitle}
      </p>
    )}
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {
        copy.offer.items.map((item, i) => {
          const service = getRebrandServiceBySlug(item.slug, lang);
          return (
            <article
              class="jpr2-surface--on-mist jpr2-fade flex h-full flex-col overflow-hidden"
              style={`transition-delay: ${i * 70}ms`}
            >
              {service && (
                <div class="relative aspect-[5/3] w-full shrink-0 overflow-hidden bg-jpr2-navy/5">
                  <img
                    src={service.heroImage}
                    alt={service.heroImageAlt}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <h3 class="text-lg font-bold text-jpr2-navy">{item.title}</h3>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-jpr2-ink/75">{item.body}</p>
                <a
                  href={rebrandServicePath(item.slug, lang)}
                  class="group mt-5 inline-flex items-center gap-2 text-sm font-semibold text-jpr2-coral transition-colors hover:text-jpr2-navy"
                >
                  {copy.offer.detailLinkLabel}
                  <svg
                    class="h-4 w-4 transition-transform duration-200 ease-out group-hover:translate-x-1"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14" />
                    <path d="m13 6 6 6-6 6" />
                  </svg>
                </a>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
