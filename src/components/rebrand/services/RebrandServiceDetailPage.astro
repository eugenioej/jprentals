---
import type { RebrandHomeCopy, RebrandLang } from '@/i18n/rebrand/home';
import type { RebrandServiceDetail } from '@/i18n/rebrand/services';
import RebrandCta from '@/components/rebrand/home/RebrandCta.astro';

interface Props {
  copy: RebrandHomeCopy;
  service: RebrandServiceDetail;
  lang: RebrandLang;
}

const { copy, service, lang } = Astro.props;

function encodeUrlPath(p: string): string {
  return `/${p
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}

const heroSrc = encodeUrlPath(service.heroImage);
const gallery = service.gallery;
const heroHeadingId = `service-hero-${service.slug}`;
---

<main class="bg-jpr2-crema">
  <section
    class="rebrand-hero-mesh jpr2-hero-frame relative flex min-h-0 flex-col overflow-hidden border-b border-jpr2-navy/10 bg-white"
    aria-labelledby={heroHeadingId}
  >
    <div
      class="pointer-events-none absolute inset-0 z-[1] opacity-[0.04]"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%231f2d4e\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
    />
    <div
      class="jpr2-hero-grid relative z-10 flex min-h-0 w-full min-w-0 flex-1 flex-col content-center items-stretch justify-center max-lg:gap-8 max-lg:py-10 sm:max-lg:py-12 lg:flex-row lg:items-stretch"
    >
      <div
        class="jpr2-hero-text order-1 flex w-full min-w-0 max-w-2xl flex-col justify-center px-4 text-left sm:px-6 lg:max-w-none lg:w-1/2 lg:flex-[0_0_50%] lg:shrink-0 lg:py-12 lg:pl-[max(1.5rem,calc((100vw-72rem)/2+1.5rem))] lg:pr-8 lg:max-xl:pr-10 xl:pr-12"
      >
        <p class="jpr2-eyebrow">{service.eyebrow}</p>
        <h1
          id={heroHeadingId}
          class="mt-3 text-3xl font-extrabold leading-tight text-jpr2-navy sm:text-4xl md:text-[2.4rem] lg:text-4xl xl:text-5xl lg:leading-[1.12]"
        >
          {service.title}
        </h1>
        <p class="mt-5 max-w-xl text-base leading-relaxed text-jpr2-ink/80 sm:mt-6">{service.lead}</p>
      </div>
      <div
        class="jpr2-hero-image-shell order-2 relative w-full min-w-0 min-h-[18rem] flex-[0_0_auto] overflow-hidden border border-jpr2-navy/10 border-r-0 bg-white sm:min-h-[20rem] sm:mx-4 lg:mx-0 lg:min-h-0 lg:w-1/2 lg:max-w-[50%] lg:shrink-0 lg:flex-[0_0_50%] lg:h-full"
      >
        <div class="absolute inset-0 h-full w-full min-h-full min-w-full">
          <img
            src={heroSrc}
            width={1200}
            height={800}
            class="absolute inset-0 h-full w-full min-h-full min-w-full object-cover object-center"
            alt={service.heroImageAlt}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <article class="overflow-x-clip border-b border-jpr2-navy/10 pt-12 pb-0 md:pt-16">
    <div class="container max-w-6xl">
      <div class="jpr2-surface--on-mist mx-auto max-w-3xl rounded-2xl border border-jpr2-navy/10 bg-white p-6 shadow-sm md:p-10">
        <div class="space-y-5">
          {
            service.paragraphs.map((p) => (
              <p class="text-base leading-relaxed text-jpr2-ink/85">{p}</p>
            ))
          }
        </div>
        {service.bullets?.length ? (
          <ul class="mt-8 list-disc space-y-2 pl-5 text-base text-jpr2-ink/85" role="list">
            {service.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        ) : null}
      </div>

      <!-- Galería a ancho de viewport; 1 col móvil, 2 cols desktop -->
      <div
        class="relative left-1/2 mt-12 grid w-screen max-w-[100vw] -translate-x-1/2 grid-cols-1 gap-4 md:mt-16 md:grid-cols-2 md:gap-5 lg:gap-6"
      >
        {
          gallery.map((img, i) => {
            const lastOdd = gallery.length % 2 === 1 && i === gallery.length - 1;
            return (
              <figure class:list={['min-w-0 overflow-hidden bg-white', lastOdd && 'md:col-span-2']}>
                <div
                  class:list={[
                    'relative w-full',
                    lastOdd
                      ? 'aspect-[4/3] sm:aspect-[3/2] md:aspect-[21/9]'
                      : 'aspect-[4/3] sm:aspect-[3/2]',
                  ]}
                >
                  {'rotate90' in img && (img as { rotate90?: boolean }).rotate90 ? (
                    <div class="absolute inset-0 overflow-hidden">
                      <img
                        src={encodeUrlPath(img.src)}
                        width={1600}
                        height={900}
                        class="absolute left-1/2 top-1/2 h-[200%] w-[200%] max-w-none -translate-x-1/2 -translate-y-1/2 rotate-90 object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
                        alt={img.alt}
                        loading={i === 0 ? 'eager' : 'lazy'}
                        decoding="async"
                      />
                    </div>
                  ) : (
                    <img
                      src={encodeUrlPath(img.src)}
                      width={1600}
                      height={900}
                      class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
                      alt={img.alt}
                      loading={i === 0 ? 'eager' : 'lazy'}
                      decoding="async"
                    />
                  )}
                </div>
              </figure>
            );
          })
        }
      </div>
    </div>
  </article>

  <RebrandCta copy={copy} />
</main>
