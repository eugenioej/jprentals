---
import type { RebrandHomeCopy, RebrandLang } from '@/i18n/rebrand/home';
import { rebrandHomePath } from '@/i18n/rebrand/home';
import type { RebrandServiceDetail } from '@/i18n/rebrand/services';
import RebrandCta from '@/components/rebrand/home/RebrandCta.astro';

interface Props {
  copy: RebrandHomeCopy;
  service: RebrandServiceDetail;
  lang: RebrandLang;
}

const { copy, service, lang } = Astro.props;
const backHref = `${rebrandHomePath(lang)}#oferta`;

function encodeUrlPath(p: string): string {
  return `/${p
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}

const heroSrc = encodeUrlPath(service.heroImage);
const gallery = service.gallery;
---

<main class="bg-jpr2-crema">
  <section class="border-b border-jpr2-navy/10 bg-jpr2-midnight pt-28 pb-12 text-white md:pt-32 md:pb-16">
    <div class="container max-w-6xl">
      <div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-6">
          <a
            href={backHref}
            class="inline-flex items-center gap-2 text-sm font-medium text-white/85 transition-colors hover:text-white"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" />
            </svg>
            {copy.servicePage.backToOffer}
          </a>
          <p class="mt-6 text-xs font-bold uppercase tracking-[0.2em] text-jpr2-coral">{service.eyebrow}</p>
          <h1 class="mt-3 text-3xl font-extrabold leading-tight md:text-4xl lg:text-[2.35rem] lg:leading-tight">
            {service.title}
          </h1>
          <p class="mt-4 text-base leading-relaxed text-white/88 md:text-lg">{service.lead}</p>
        </div>
        <figure class="relative overflow-hidden rounded-2xl border border-white/15 shadow-[0_20px_50px_rgba(5,9,18,0.45)] lg:col-span-6">
          <div class="aspect-[4/3] w-full sm:aspect-[16/10] lg:aspect-[5/4]">
            <img
              src={heroSrc}
              width={1200}
              height={800}
              class="h-full w-full object-cover"
              alt={service.heroImageAlt}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
          <div
            class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-jpr2-midnight/25 via-transparent to-transparent"
            aria-hidden="true"
          />
        </figure>
      </div>
    </div>
  </section>

  <article class="border-b border-jpr2-navy/10 py-12 md:py-16">
    <div class="container max-w-6xl">
      <div class="jpr2-surface--on-mist mx-auto max-w-3xl rounded-2xl border border-jpr2-navy/10 bg-white p-6 shadow-sm md:p-10">
        <div class="space-y-5">
          {
            service.paragraphs.map((p) => (
              <p class="text-sm leading-relaxed text-jpr2-ink/85 md:text-base">{p}</p>
            ))
          }
        </div>
        {service.bullets?.length ? (
          <ul class="mt-8 list-disc space-y-2 pl-5 text-sm text-jpr2-ink/85 md:text-base" role="list">
            {service.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        ) : null}
      </div>

      <div class="mx-auto mt-10 grid max-w-5xl gap-4 sm:grid-cols-2 md:mt-12 md:gap-5">
        {
          gallery.map((img, i) => (
            <figure class="overflow-hidden rounded-2xl border border-jpr2-navy/10 bg-white shadow-[0_6px_28px_rgba(10,15,30,0.08)]">
              <div class="aspect-[4/3] w-full sm:aspect-[3/2]">
                <img
                  src={encodeUrlPath(img.src)}
                  width={1200}
                  height={800}
                  class="h-full w-full object-cover transition-transform duration-500 hover:scale-[1.02]"
                  alt=""
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <figcaption class="border-t border-jpr2-navy/8 px-4 py-3 text-xs leading-snug text-jpr2-ink/75 md:text-sm">
                {img.alt}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </article>

  <RebrandCta copy={copy} />
</main>
