---
import type { RebrandHomeCopy, RebrandLang } from '@/i18n/rebrand/home';

type LinkBlock = (typeof import('@/i18n/rebrand/home'))['rebrandHomeLinks'][RebrandLang];

/** Props kept so existing pages do not need changes; footer content is fixed minimal. */
interface Props {
  copy: RebrandHomeCopy;
  links: LinkBlock;
  lang: RebrandLang;
}

void Astro.props;
---

<footer class="mt-0 border-t border-jpr2-navy/10 bg-jpr2-crema">
  <div class="container max-w-6xl py-6 md:py-7">
    <p class="text-center text-[0.7rem] font-medium tracking-wide text-jpr2-ink/45 md:text-xs">
      © {new Date().getFullYear()} JP Rentals
    </p>
  </div>
</footer>
