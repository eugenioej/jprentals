---
import type { RebrandHomeCopy, RebrandLang, RebrandSuccessCase } from '@/i18n/rebrand/home';
import { rebrandHomePath } from '@/i18n/rebrand/home';

interface Props {
  copy: RebrandHomeCopy;
  lang: RebrandLang;
  item: RebrandSuccessCase;
}

const { copy, lang, item } = Astro.props;
const pp = copy.projectPage;
const sc = copy.successCases;

function encodeUrlPath(p: string): string {
  return `/${p
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}

const backHref = `${rebrandHomePath(lang)}#casos`;

const i18nJson = JSON.stringify({
  lightboxCaption: pp.lightboxCaption,
  lightboxAria: pp.lightboxAria,
  lightboxClose: pp.lightboxClose,
  lightboxPrev: pp.lightboxPrev,
  lightboxNext: pp.lightboxNext,
});
---

<main class="bg-jpr2-crema">
  <section class="border-b border-jpr2-navy/10 bg-jpr2-midnight pt-28 pb-12 text-white md:pt-32 md:pb-16">
    <div class="container max-w-6xl">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm font-medium text-white/85 transition-colors hover:text-white"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
        {pp.backToCases}
      </a>
      <p class="mt-6 text-xs font-bold uppercase tracking-[0.2em] text-jpr2-coral">
        {item.year} · {item.client}
      </p>
      <h1 class="mt-3 max-w-4xl text-3xl font-extrabold leading-tight text-white md:text-5xl">
        {item.title}
      </h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-white/85 md:text-base">
        {item.scope}
      </p>
    </div>
  </section>

  <section class="border-b border-jpr2-navy/10 py-12 md:py-16">
    <div class="container max-w-6xl">
      <h2 class="text-xl font-extrabold text-jpr2-navy md:text-2xl">{pp.detailsTitle}</h2>
      <dl class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.client}</dt>
          <dd class="mt-1 text-sm font-semibold text-jpr2-ink">{item.client}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.location}</dt>
          <dd class="mt-1 text-sm font-semibold text-jpr2-ink">{item.location}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.area}</dt>
          <dd class="mt-1 text-sm font-semibold text-jpr2-ink">{item.area}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.steel}</dt>
          <dd class="mt-1 text-sm font-semibold text-jpr2-ink">{item.steel}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="container max-w-6xl">
      <h2 class="text-xl font-extrabold text-jpr2-navy md:text-2xl">{pp.galleryTitle}</h2>
      <p class="mt-2 text-sm text-jpr2-ink/70">{pp.galleryHint}</p>
      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          item.images.map((image, index) => (
            <figure class="overflow-hidden rounded-xl border border-jpr2-navy/12 bg-white shadow-sm">
              <button
                type="button"
                class="group block w-full cursor-zoom-in"
                data-project-gallery-item
                data-index={index}
                aria-label={pp.openImageAria.replace('{n}', String(index + 1))}
              >
                <img
                  src={encodeUrlPath(image)}
                  width={1200}
                  height={900}
                  loading={index < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="aspect-[4/3] h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  alt={`${item.imageAlt} — ${index + 1}`}
                />
              </button>
            </figure>
          ))
        }
      </div>
    </div>
  </section>
</main>

<script type="application/json" id="jpr2-pj-lightbox-i18n" set:html={i18nJson} />

<div
  class="fixed inset-0 z-[120] hidden items-center justify-center bg-black/90 p-4 md:p-8"
  data-project-lightbox
  role="dialog"
  aria-modal="true"
  aria-label={pp.lightboxAria}
>
  <button
    type="button"
    class="absolute right-3 top-3 rounded-full border border-white/25 bg-black/40 p-2 text-white transition-colors hover:bg-black/70 md:right-6 md:top-6"
    data-project-lightbox-close
    aria-label={pp.lightboxClose}
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M18 6 6 18" />
      <path d="m6 6 12 12" />
    </svg>
  </button>

  <button
    type="button"
    class="absolute left-2 top-1/2 -translate-y-1/2 rounded-full border border-white/25 bg-black/40 p-2 text-white transition-colors hover:bg-black/70 md:left-6"
    data-project-lightbox-prev
    aria-label={pp.lightboxPrev}
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>

  <figure class="max-h-full max-w-[min(1200px,92vw)]">
    <img
      src=""
      alt=""
      class="max-h-[84vh] w-auto max-w-full rounded-lg object-contain"
      data-project-lightbox-image
    />
    <figcaption class="mt-3 text-center text-sm text-white/85" data-project-lightbox-caption />
  </figure>

  <button
    type="button"
    class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full border border-white/25 bg-black/40 p-2 text-white transition-colors hover:bg-black/70 md:right-6"
    data-project-lightbox-next
    aria-label={pp.lightboxNext}
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="m9 18 6-6-6-6" />
    </svg>
  </button>
</div>

<script is:inline>
  (() => {
    const cfgEl = document.getElementById('jpr2-pj-lightbox-i18n');
    let cfg = {
      lightboxCaption: 'Image {current} of {total}',
      lightboxAria: '',
      lightboxClose: 'Close',
      lightboxPrev: 'Previous',
      lightboxNext: 'Next',
    };
    try {
      if (cfgEl && cfgEl.textContent) cfg = Object.assign(cfg, JSON.parse(cfgEl.textContent));
    } catch (e) {}

    const thumbs = Array.from(document.querySelectorAll('[data-project-gallery-item]'));
    const lightbox = document.querySelector('[data-project-lightbox]');
    if (!thumbs.length || !lightbox) return;

    const imageEl = lightbox.querySelector('[data-project-lightbox-image]');
    const captionEl = lightbox.querySelector('[data-project-lightbox-caption]');
    const closeBtn = lightbox.querySelector('[data-project-lightbox-close]');
    const prevBtn = lightbox.querySelector('[data-project-lightbox-prev]');
    const nextBtn = lightbox.querySelector('[data-project-lightbox-next]');
    if (!imageEl || !captionEl || !closeBtn || !prevBtn || !nextBtn) return;

    const images = thumbs.map((button, idx) => {
      const img = button.querySelector('img');
      return {
        src: img?.getAttribute('src') ?? '',
        alt: img?.getAttribute('alt') ?? '',
        caption: cfg.lightboxCaption
          .replace('{current}', String(idx + 1))
          .replace('{total}', String(thumbs.length)),
      };
    });

    let current = 0;
    let open = false;

    const render = () => {
      const item = images[current];
      imageEl.setAttribute('src', item.src);
      imageEl.setAttribute('alt', item.alt);
      captionEl.textContent = item.caption;
    };

    const show = (index) => {
      current = (index + images.length) % images.length;
      render();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      open = true;
    };

    const hide = () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      open = false;
    };

    thumbs.forEach((btn, i) => {
      btn.addEventListener('click', () => show(i));
    });

    closeBtn.addEventListener('click', hide);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current - 1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current + 1);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) hide();
    });

    window.addEventListener('keydown', (e) => {
      if (!open) return;
      if (e.key === 'Escape') hide();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
