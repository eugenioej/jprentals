---
import type { RebrandHomeCopy, RebrandLang, RebrandSuccessCase } from '@/i18n/rebrand/home';
import RebrandCta from '@/components/rebrand/home/RebrandCta.astro';

interface Props {
  copy: RebrandHomeCopy;
  lang: RebrandLang;
  item: RebrandSuccessCase;
}

const { copy, lang, item } = Astro.props;
const pp = copy.projectPage;
const sc = copy.successCases;

function encodeUrlPath(p: string): string {
  return `/${p
    .split('/')
    .filter(Boolean)
    .map((segment) => encodeURIComponent(segment))
    .join('/')}`;
}

const i18nJson = JSON.stringify({
  lightboxCaption: pp.lightboxCaption,
  lightboxAria: pp.lightboxAria,
  lightboxClose: pp.lightboxClose,
  lightboxPrev: pp.lightboxPrev,
  lightboxNext: pp.lightboxNext,
});
---

<main class="bg-jpr2-crema">
  <section class="border-b border-jpr2-navy/10 bg-white pt-28 pb-12 md:pt-32 md:pb-16">
    <div class="container max-w-6xl">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-jpr2-coral">
        {item.year} · {item.client}
      </p>
      <h1 class="mt-3 max-w-4xl text-3xl font-extrabold leading-tight text-jpr2-navy md:text-5xl">
        {item.title}
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-jpr2-ink/85">
        {item.scope}
      </p>
    </div>
  </section>

  <section class="border-b border-jpr2-navy/10 py-12 md:py-16">
    <div class="container max-w-6xl">
      <h2 class="text-xl font-extrabold text-jpr2-navy md:text-2xl">{pp.detailsTitle}</h2>
      <dl class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.client}</dt>
          <dd class="mt-1 text-base font-semibold text-jpr2-ink">{item.client}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.location}</dt>
          <dd class="mt-1 text-base font-semibold text-jpr2-ink">{item.location}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.area}</dt>
          <dd class="mt-1 text-base font-semibold text-jpr2-ink">{item.area}</dd>
        </div>
        <div class="rounded-xl border border-jpr2-navy/12 bg-white p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-jpr2-muted">{sc.labels.steel}</dt>
          <dd class="mt-1 text-base font-semibold text-jpr2-ink">{item.steel}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="overflow-x-clip border-b border-jpr2-navy/10 pt-12 pb-0 md:pt-16 md:pb-0">
    <div
      class="relative left-1/2 grid w-screen max-w-[100vw] -translate-x-1/2 grid-cols-1 gap-4 md:grid-cols-2 md:gap-5 lg:gap-6"
    >
      {
        item.images.map((image, index) => {
          const imgs = item.images;
          const lastOdd = imgs.length % 2 === 1 && index === imgs.length - 1;
          return (
            <figure class:list={['min-w-0 overflow-hidden bg-white', lastOdd && 'md:col-span-2']}>
              <button
                type="button"
                class="group block w-full cursor-zoom-in"
                data-project-gallery-item
                data-index={index}
                aria-label={pp.openImageAria.replace('{n}', String(index + 1))}
              >
                <div
                  class:list={[
                    'relative w-full',
                    lastOdd
                      ? 'aspect-[4/3] sm:aspect-[3/2] md:aspect-[21/9]'
                      : 'aspect-[4/3] sm:aspect-[3/2]',
                  ]}
                >
                  <img
                    src={encodeUrlPath(image)}
                    width={1600}
                    height={900}
                    class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-[1.015]"
                    alt={`${item.imageAlt} — ${index + 1}`}
                    loading={index < 2 ? 'eager' : 'lazy'}
                    decoding="async"
                  />
                </div>
              </button>
            </figure>
          );
        })
      }
    </div>
  </section>

  <RebrandCta copy={copy} />
</main>

<script type="application/json" id="jpr2-pj-lightbox-i18n" set:html={i18nJson} />

<div
  class="fixed inset-0 z-[120] hidden items-center justify-center bg-jpr2-crema/95 p-4 backdrop-blur-sm md:p-8"
  data-project-lightbox
  role="dialog"
  aria-modal="true"
  aria-label={pp.lightboxAria}
>
  <button
    type="button"
    class="absolute right-3 top-3 rounded-full border border-jpr2-navy/15 bg-white p-2 text-jpr2-navy shadow-sm transition-colors hover:border-jpr2-coral/30 hover:text-jpr2-coral md:right-6 md:top-6"
    data-project-lightbox-close
    aria-label={pp.lightboxClose}
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M18 6 6 18" />
      <path d="m6 6 12 12" />
    </svg>
  </button>

  <button
    type="button"
    class="absolute left-2 top-1/2 -translate-y-1/2 rounded-full border border-jpr2-navy/15 bg-white p-2 text-jpr2-navy shadow-sm transition-colors hover:border-jpr2-coral/30 hover:text-jpr2-coral md:left-6"
    data-project-lightbox-prev
    aria-label={pp.lightboxPrev}
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" />
    </svg>
  </button>

  <figure class="max-h-full max-w-[min(1200px,92vw)]">
    <img
      src=""
      alt=""
      class="max-h-[84vh] w-auto max-w-full rounded-lg object-contain shadow-md"
      data-project-lightbox-image
    />
    <figcaption class="mt-3 text-center text-base text-jpr2-ink/80" data-project-lightbox-caption />
  </figure>

  <button
    type="button"
    class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full border border-jpr2-navy/15 bg-white p-2 text-jpr2-navy shadow-sm transition-colors hover:border-jpr2-coral/30 hover:text-jpr2-coral md:right-6"
    data-project-lightbox-next
    aria-label={pp.lightboxNext}
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="m9 18 6-6-6-6" />
    </svg>
  </button>
</div>

<script is:inline>
  (() => {
    const cfgEl = document.getElementById('jpr2-pj-lightbox-i18n');
    let cfg = {
      lightboxCaption: 'Image {current} of {total}',
      lightboxAria: '',
      lightboxClose: 'Close',
      lightboxPrev: 'Previous',
      lightboxNext: 'Next',
    };
    try {
      if (cfgEl && cfgEl.textContent) cfg = Object.assign(cfg, JSON.parse(cfgEl.textContent));
    } catch (e) {}

    const thumbs = Array.from(document.querySelectorAll('[data-project-gallery-item]'));
    const lightbox = document.querySelector('[data-project-lightbox]');
    if (!thumbs.length || !lightbox) return;

    const imageEl = lightbox.querySelector('[data-project-lightbox-image]');
    const captionEl = lightbox.querySelector('[data-project-lightbox-caption]');
    const closeBtn = lightbox.querySelector('[data-project-lightbox-close]');
    const prevBtn = lightbox.querySelector('[data-project-lightbox-prev]');
    const nextBtn = lightbox.querySelector('[data-project-lightbox-next]');
    if (!imageEl || !captionEl || !closeBtn || !prevBtn || !nextBtn) return;

    const images = thumbs.map((button, idx) => {
      const img = button.querySelector('img');
      return {
        src: img?.getAttribute('src') ?? '',
        alt: img?.getAttribute('alt') ?? '',
        caption: cfg.lightboxCaption
          .replace('{current}', String(idx + 1))
          .replace('{total}', String(thumbs.length)),
      };
    });

    let current = 0;
    let open = false;

    const render = () => {
      const item = images[current];
      imageEl.setAttribute('src', item.src);
      imageEl.setAttribute('alt', item.alt);
      captionEl.textContent = item.caption;
    };

    const show = (index) => {
      current = (index + images.length) % images.length;
      render();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
      open = true;
    };

    const hide = () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
      open = false;
    };

    thumbs.forEach((btn, i) => {
      btn.addEventListener('click', () => show(i));
    });

    closeBtn.addEventListener('click', hide);
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current - 1);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      show(current + 1);
    });

    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) hide();
    });

    window.addEventListener('keydown', (e) => {
      if (!open) return;
      if (e.key === 'Escape') hide();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
