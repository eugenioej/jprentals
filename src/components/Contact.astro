---
import type { Locale } from '@/i18n/utils';
import { t, waLink, phoneLink } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<section id="contacto" class="section-padding bg-brand-white">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Left: Form -->
      <div>
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-4">
          {i.contact.title}
        </h2>
        <p class="text-lg text-brand-500 mb-8">
          {i.contact.subtitle}
        </p>

        <form class="space-y-4" data-contact-form>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="name" class="block text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1.5">
                {i.contact.form.name}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-brand-50 border border-brand-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-black focus:border-transparent transition-all"
              />
            </div>
            <div>
              <label for="company" class="block text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1.5">
                {i.contact.form.company}
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 bg-brand-50 border border-brand-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-black focus:border-transparent transition-all"
              />
            </div>
          </div>

          <div>
            <label for="phone" class="block text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1.5">
              {i.contact.form.phone}
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full px-4 py-3 bg-brand-50 border border-brand-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-black focus:border-transparent transition-all"
            />
          </div>

          <div>
            <label for="service" class="block text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1.5">
              {i.contact.form.service}
            </label>
            <select
              id="service"
              name="service"
              required
              class="w-full px-4 py-3 bg-brand-50 border border-brand-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-black focus:border-transparent transition-all appearance-none"
            >
              <option value="">—</option>
              {i.contact.form.service_options.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="message" class="block text-xs font-semibold text-brand-500 uppercase tracking-wider mb-1.5">
              {i.contact.form.message}
            </label>
            <textarea
              id="message"
              name="message"
              rows="3"
              class="w-full px-4 py-3 bg-brand-50 border border-brand-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-black focus:border-transparent transition-all resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center !py-4">
            {i.contact.form.submit}
          </button>
        </form>
      </div>

      <!-- Right: WhatsApp & Info -->
      <div class="lg:sticky lg:top-28">
        <!-- WhatsApp card -->
        <div class="bg-brand-black text-white rounded-2xl p-8 mb-6">
          <p class="text-sm text-brand-400 mb-4">{i.contact.or}</p>
          <a
            href={waLink(i.contact.wa_message)}
            target="_blank"
            rel="noopener"
            class="btn-wa w-full justify-center !py-4 !text-base"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.553 4.12 1.525 5.857L.058 23.708l5.989-1.572A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.964 0-3.834-.529-5.47-1.529l-.393-.233-3.554.934.948-3.467-.255-.406A9.813 9.813 0 012.18 12c0-5.422 4.398-9.82 9.82-9.82 5.422 0 9.82 4.398 9.82 9.82 0 5.422-4.398 9.82-9.82 9.82z"/></svg>
            {i.contact.wa_button}
          </a>
          <div class="mt-6 pt-6 border-t border-white/10">
            <a href={phoneLink()} class="flex items-center gap-3 text-brand-300 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <span class="text-sm font-medium">+52 (81) 1600-7864</span>
            </a>
          </div>
        </div>

        <!-- Info cards -->
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-brand-50 border border-brand-200 rounded-xl p-5 text-center">
            <svg class="w-6 h-6 mx-auto mb-2 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <p class="text-xs text-brand-500 leading-snug">{i.contact.schedule}</p>
          </div>
          <div class="bg-brand-50 border border-brand-200 rounded-xl p-5 text-center">
            <svg class="w-6 h-6 mx-auto mb-2 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            <p class="text-xs text-brand-500 leading-snug">{i.contact.response_time}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
