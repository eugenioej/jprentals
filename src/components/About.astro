---
import type { Locale } from '@/i18n/utils';
import { t } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const icons: Record<string, string> = {
  building: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  truck: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/></svg>`,
  clock: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  map: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
};
---

<section id="nosotros" class="section-padding bg-brand-white">
  <div class="container">
    <!-- Stats bar -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-16">
      {i.about.stats.map((stat) => (
        <div class="fade-in bg-accent text-white rounded-2xl p-6 md:p-8 text-center">
          <div class="text-3xl md:text-4xl font-extrabold tracking-tight leading-none mb-1">
            {stat.value}
          </div>
          <div class="text-xs md:text-sm font-medium text-white/70">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Two-column layout: text + trust points | image -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

      <!-- Left: header + trust points -->
      <div>
        <div class="mb-10">
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight mb-4">
            {i.about.title}
          </h2>
          <p class="text-lg text-brand-700 max-w-2xl leading-relaxed">
            {i.about.subtitle}
          </p>
        </div>

        <div class="grid gap-4 stagger-children">
          {i.about.items.map((item) => (
            <div class="fade-in flex gap-5 p-6 bg-brand-50 border border-brand-200 rounded-2xl transition-all duration-300 hover:border-brand-300 hover:shadow-md">
              <div class="w-14 h-14 bg-accent rounded-xl flex items-center justify-center text-white shrink-0">
                <Fragment set:html={icons[item.icon]} />
              </div>
              <div>
                <h3 class="text-lg font-bold tracking-tight mb-2">{item.title}</h3>
                <p class="text-sm text-brand-600 leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: placeholder image -->
      <div class="fade-in lg:sticky lg:top-28">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/5]">
          <img
            src="/images/jp-rentals-flota-4.webp"
            alt="Flota completa de JP Rentals — grúas industriales y camiones en patio Monterrey"
            title="JP Rentals — Flota de grúas industriales y vehículos de carga en Monterrey"
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>

    </div>

    <!-- Sister brands -->
    <div class="mt-12 p-8 bg-brand-900 rounded-2xl text-white fade-in">
      <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-12">
        <div class="flex-1">
          <p class="text-sm text-brand-300 leading-relaxed">
            JP Rentals forma parte de Grupo NASA, junto con Nasacero (corte y transformación de acero) y Nacional de Anclas (anclajes de cimentación). Más de 30 años en la industria del acero y construcción en Monterrey.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a href="https://nasacero.com" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-white/20 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:border-white/40 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            Nasacero
          </a>
          <a href="https://nacionaldeanclas.com" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 border border-white/20 rounded-lg text-sm font-medium text-white/80 hover:text-white hover:border-white/40 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
            Nacional de Anclas
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
