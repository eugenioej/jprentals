---
import type { Locale } from '@/i18n/utils';
import { t, waLink } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);

const icons: Record<string, string> = {
  crane: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M5 21V7l8-4v18M13 21V5l6 3v13M9 9h.01M9 13h.01M9 17h.01M17 9h.01M17 13h.01M17 17h.01"/></svg>`,
  truck: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8zM5.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM18.5 21a2.5 2.5 0 100-5 2.5 2.5 0 000 5z"/></svg>`,
  calendar: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
};
---

<section id="servicios" class="section-padding bg-brand-white">
  <div class="container">
    <!-- Section header -->
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight mb-4">
        {i.services.title}
      </h2>
      <p class="text-lg text-brand-500 max-w-2xl leading-relaxed">
        {i.services.subtitle}
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid md:grid-cols-3 gap-6 stagger-children">
      {i.services.items.map((service, idx) => (
        <div class="fade-in group relative bg-brand-50 border border-brand-200 rounded-2xl p-8 transition-all duration-300 hover:border-brand-300 hover:shadow-lg hover:shadow-black/[0.03] flex flex-col">
          <!-- Icon -->
          <div class="w-14 h-14 bg-accent rounded-xl flex items-center justify-center mb-6 text-white group-hover:scale-105 transition-transform">
            <Fragment set:html={icons[service.icon]} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold tracking-tight mb-3">
            {service.title}
          </h3>
          <p class="text-sm text-brand-500 leading-relaxed mb-6">
            {service.description}
          </p>

          <!-- Features -->
          <ul class="space-y-2 mb-8 flex-grow">
            {service.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-brand-600">
                <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={waLink(service.wa_message)}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2 w-full px-6 py-3 bg-accent text-white text-sm font-semibold rounded-lg transition-all duration-200 hover:bg-accent-dark group-hover:shadow-md"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.553 4.12 1.525 5.857L.058 23.708l5.989-1.572A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.964 0-3.834-.529-5.47-1.529l-.393-.233-3.554.934.948-3.467-.255-.406A9.813 9.813 0 012.18 12c0-5.422 4.398-9.82 9.82-9.82 5.422 0 9.82 4.398 9.82 9.82 0 5.422-4.398 9.82-9.82 9.82z"/></svg>
            {i.services.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
