---
interface Props {
  title: string;
  faqs: { q: string; a: string }[];
}

const { title, faqs } = Astro.props;
---

<section class="mb-12 md:mb-16">
  <h2 class="text-2xl font-extrabold mb-8 inner-fade text-brand-900">{title}</h2>
  <div class="space-y-4 max-w-3xl">
    {
      faqs.map((faq) => (
        <details class="inner-fade border border-brand-200 rounded-xl p-5 group bg-white">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between gap-4 text-brand-900">
            {faq.q}
            <svg
              class="w-4 h-4 text-brand-400 shrink-0 group-open:rotate-180 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="mt-3 text-brand-600 text-sm leading-relaxed">{faq.a}</p>
        </details>
      ))
    }
  </div>
</section>
