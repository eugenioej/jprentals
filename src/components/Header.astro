---
import type { Locale } from '@/i18n/utils';
import { t, getAlternateUrl, waLink } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
const altLocale: Locale = locale === 'es' ? 'en' : 'es';
const altUrl = getAlternateUrl(Astro.url, altLocale);
const altLabel = locale === 'es' ? 'EN' : 'ES';
---

<header id="header" class="transition-all duration-300" data-header>
  <div class="container flex items-center justify-between h-16 md:h-20">
    <!-- Logo -->
    <a href={locale === 'es' ? '/' : '/en/'} class="flex items-center gap-2 shrink-0">
      <span class="nav-logo text-lg md:text-xl font-extrabold tracking-tight text-white transition-colors duration-300">
        JP Rentals
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1">
      <a href="#servicios" class="nav-link px-4 py-2 text-sm font-medium text-white/90 hover:text-white rounded-lg transition-colors duration-300">
        {i.nav.services}
      </a>
      <a href="#equipos" class="nav-link px-4 py-2 text-sm font-medium text-white/90 hover:text-white rounded-lg transition-colors duration-300">
        {i.nav.equipment}
      </a>
      <a href="#nosotros" class="nav-link px-4 py-2 text-sm font-medium text-white/90 hover:text-white rounded-lg transition-colors duration-300">
        {i.nav.about}
      </a>
      <a href="#contacto" class="nav-link px-4 py-2 text-sm font-medium text-white/90 hover:text-white rounded-lg transition-colors duration-300">
        {i.nav.contact}
      </a>
      <a href={altUrl} class="nav-lang px-3 py-2 text-xs font-bold text-white/70 hover:text-white border border-white/30 rounded-md transition-colors duration-300 ml-2">
        {altLabel}
      </a>
      <a href={waLink(i.contact.wa_message)} target="_blank" rel="noopener" class="btn-primary ml-3 !py-2.5 !px-5 !text-xs">
        {i.nav.cta}
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <div class="flex items-center gap-3 md:hidden">
      <a href={altUrl} class="nav-lang px-2 py-1 text-xs font-bold text-white/70 hover:text-white border border-white/30 rounded transition-colors duration-300">
        {altLabel}
      </a>
      <button id="menu-toggle" type="button" class="p-2 -mr-2 text-white" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-brand-200">
    <div class="container py-4 flex flex-col gap-1">
      <a href="#servicios" class="px-4 py-3 text-sm font-medium text-brand-600 hover:text-brand-black hover:bg-brand-50 rounded-lg transition-colors mobile-nav-link">
        {i.nav.services}
      </a>
      <a href="#equipos" class="px-4 py-3 text-sm font-medium text-brand-600 hover:text-brand-black hover:bg-brand-50 rounded-lg transition-colors mobile-nav-link">
        {i.nav.equipment}
      </a>
      <a href="#nosotros" class="px-4 py-3 text-sm font-medium text-brand-600 hover:text-brand-black hover:bg-brand-50 rounded-lg transition-colors mobile-nav-link">
        {i.nav.about}
      </a>
      <a href="#contacto" class="px-4 py-3 text-sm font-medium text-brand-600 hover:text-brand-black hover:bg-brand-50 rounded-lg transition-colors mobile-nav-link">
        {i.nav.contact}
      </a>
      <a href={waLink(i.contact.wa_message)} target="_blank" rel="noopener" class="btn-wa mt-2 justify-center">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.553 4.12 1.525 5.857L.058 23.708l5.989-1.572A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-1.964 0-3.834-.529-5.47-1.529l-.393-.233-3.554.934.948-3.467-.255-.406A9.813 9.813 0 012.18 12c0-5.422 4.398-9.82 9.82-9.82 5.422 0 9.82 4.398 9.82 9.82 0 5.422-4.398 9.82-9.82 9.82z"/></svg>
        {i.nav.cta}
      </a>
    </div>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.querySelector('[data-header]') as HTMLElement;
  let lastScroll = 0;

  const navLinks = document.querySelectorAll('.nav-link') as NodeListOf<HTMLElement>;
  const navLangs = document.querySelectorAll('.nav-lang') as NodeListOf<HTMLElement>;
  const navLogo = document.querySelector('.nav-logo') as HTMLElement;
  const menuToggle = document.getElementById('menu-toggle');

  function updateHeader() {
    const scroll = window.scrollY;
    if (scroll > 60) {
      header.classList.add('bg-white/95', 'backdrop-blur-lg', 'shadow-sm', 'border-b', 'border-brand-200/50');
      header.classList.remove('bg-transparent');
      navLinks.forEach(el => { el.classList.remove('text-white/90', 'hover:text-white'); el.classList.add('text-brand-600'); });
      navLangs.forEach(el => { el.classList.remove('text-white/70', 'hover:text-white', 'border-white/30'); el.classList.add('text-brand-400', 'border-brand-200'); });
      if (navLogo) { navLogo.classList.remove('text-white'); navLogo.classList.add('text-brand-black'); }
      if (menuToggle) menuToggle.classList.replace('text-white', 'text-brand-black');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-lg', 'shadow-sm', 'border-b', 'border-brand-200/50');
      header.classList.add('bg-transparent');
      navLinks.forEach(el => { el.classList.add('text-white/90', 'hover:text-white'); el.classList.remove('text-brand-600'); });
      navLangs.forEach(el => { el.classList.add('text-white/70', 'hover:text-white', 'border-white/30'); el.classList.remove('text-brand-400', 'border-brand-200'); });
      if (navLogo) { navLogo.classList.add('text-white'); navLogo.classList.remove('text-brand-black'); }
      if (menuToggle) menuToggle.classList.replace('text-brand-black', 'text-white');
    }
    lastScroll = scroll;
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    if (isOpen) {
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    } else {
      icon?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  });

  // Close menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      icon?.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
    });
  });
</script>
