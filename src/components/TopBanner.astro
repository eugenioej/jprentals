---
import type { Locale } from '@/i18n/utils';
import { waLink } from '@/i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = locale === 'es'
  ? [
      '🏗️ Grúas industriales de 8 a 50 toneladas disponibles',
      '📦 Flete local con tráiler hasta 30 toneladas',
      '⚡ Cotización en menos de 1 hora',
      '🏭 Servicio para plantas industriales en toda el área metropolitana',
      '📐 Plataforma extensible hasta 60 metros',
      '🔧 Parte de Grupo NASA — 30+ años en la industria',
    ]
  : [
      '🏗️ Industrial cranes from 8 to 50 tons available',
      '📦 Local hauling with trailer up to 30 tons',
      '⚡ Quote in under 1 hour',
      '🏭 Service for industrial plants across the metropolitan area',
      '📐 Extendable platform up to 60 meters',
      '🔧 Part of Grupo NASA — 30+ years in industry',
    ];

const waMsg = locale === 'es'
  ? 'Hola JP Rentals, me interesa cotizar un servicio.'
  : 'Hi JP Rentals, I would like to get a quote.';
---

<div id="top-banner" class="bg-accent text-white overflow-hidden" style="height: 36px;">
  <div class="ticker-wrapper h-full flex items-center">
    <div class="ticker-track flex items-center gap-0 whitespace-nowrap">
      {[...items, ...items].map((item) => (
        <span class="ticker-item inline-flex items-center text-xs font-medium px-8">
          {item}
          <span class="mx-8 opacity-30">|</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .ticker-wrapper {
    width: 100%;
    overflow: hidden;
  }

  .ticker-track {
    display: inline-flex;
    animation: ticker 40s linear infinite;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
