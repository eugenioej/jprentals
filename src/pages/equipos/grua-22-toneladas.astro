---
import InnerLayout from '@/layouts/InnerLayout.astro';
import EquipmentFAQ from '@/components/equipment/EquipmentFAQ.astro';
import { buildFaqPageSchema } from '@/lib/faq-schema';

const faqs = [
  {
    q: '¿Para qué proyectos industriales se usa una grúa de 22 toneladas?',
    a: 'Es ideal para proyectos de manufactura medianos: centros CNC, prensas, equipos de proceso, transformadores y maquinaria de planta que supera cómodamente a una grúa de 15–18 t pero no requiere aún los 50 toneladas. También para izaje en obra industrial con cargas pesadas intermedias.',
  },
  {
    q: '¿La renta de grúa de 22T en Monterrey incluye operador?',
    a: 'Sí. El servicio incluye operador certificado; es el modelo estándar de JP Rentals para todas las rentas de grúa con maniobra.',
  },
  {
    q: '¿Pueden mover maquinaria pesada entre líneas dentro de la misma planta?',
    a: 'Sí, siempre que haya ruta de maniobra viable: evaluamos anchos de pasillo, puertas y obstáculos. Si el peso o geometría lo exigen, escogemos el equipo y el método de izaje adecuados.',
  },
  {
    q: '¿Operan solo en Monterrey y AMM?',
    a: 'El servicio principal es Monterrey y Área Metropolitana de Nuevo León. Para sitios fuera del AMM, pregunta por disponibilidad y costo de traslado del equipo.',
  },
  {
    q: '¿Qué datos necesitan para cotizar renta de grúa de 22 toneladas?',
    a: 'Peso y dimensiones aproximados, origen y destino de la maniobra (si aplica), dirección y ventana de fecha. Con eso cotizamos por WhatsApp al +52 81 1600 7864.',
  },
];

const schema = buildFaqPageSchema(faqs);
---
<InnerLayout locale="es" title="Renta de Grúa de 22 Toneladas en Monterrey | JP Rentals" description="Renta de grúa convencional de 22 toneladas en Monterrey. Versátil para proyectos industriales medianos, traslado de maquinaria y maniobras en planta. Cotiza por WhatsApp." canonical="https://jprentals.mx/equipos/grua-22-toneladas" altHref="https://jprentals.mx/en/equipment/22-ton-crane" altLocale="en" schema={schema}>
  <span slot="breadcrumb"><a href="/servicios/renta-gruas-industriales" class="hover:text-white/80">Renta de grúas industriales</a> / Grúa 22T</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">Renta de Grúa Convencional <span class="text-blue-300">22 Toneladas</span><br/><span class="text-white/80">en Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Renta de grúa versátil para proyectos industriales medianos: traslado de maquinaria de manufactura, equipos de proceso y maniobras en plantas y naves industriales.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 mb-16 items-center">
        <div class="inner-fade rounded-2xl overflow-hidden aspect-[4/3] bg-brand-100">
          <img src="/images/grua-22t.webp" alt="Renta de grúa convencional 22 toneladas JP Rentals Monterrey" width="600" height="450" class="w-full h-full object-cover" loading="eager" />
        </div>
        <div class="inner-fade">
          <h2 class="text-xl font-bold mb-4">Especificaciones</h2>
          <dl class="space-y-3">
            {[['Capacidad máxima','22 toneladas'],['Tipo','Grúa convencional telescópica'],['Disponibilidad','Renta diaria, semanal, mensual'],['Área de operación','Monterrey y área metropolitana'],['Operador','Incluido en el servicio'],['Empresa','JP Rentals — Grupo NASA']].map(([k,v]) => (
              <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">{k}</dt><dd class="text-sm font-semibold">{v}</dd></div>
            ))}
          </dl>
        </div>
      </div>
      <h2 class="text-2xl font-extrabold mb-6 inner-fade">Usos principales</h2>
      <div class="grid md:grid-cols-2 gap-4 mb-16">
        {['Maquinaria CNC y centros de maquinado','Equipos de inyección y moldeo','Compresores y bombas industriales','Transformadores y tableros eléctricos','Maniobras en plantas automotrices','Montaje en proyectos de manufactura'].map(u => (
          <div class="inner-fade flex items-start gap-3 p-4 bg-brand-50 border border-brand-200 rounded-xl">
            <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-medium">{u}</span>
          </div>
        ))}
      </div>
      <EquipmentFAQ title="Preguntas frecuentes — grúa de 22 toneladas en Monterrey" faqs={faqs} />
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Otras grúas disponibles</p>
        <div class="flex flex-wrap gap-3">
          {[['Grúa 50T','/equipos/grua-50-toneladas'],['Grúa 18T','/equipos/grua-18-toneladas'],['Grúa 15T','/equipos/grua-15-toneladas'],['Grúa articulada 8T','/equipos/grua-articulada-8-toneladas']].map(([l,h]) => (
            <a href={h} class="text-sm font-medium text-accent hover:underline">→ {l}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
