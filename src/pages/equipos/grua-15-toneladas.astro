---
import InnerLayout from '@/layouts/InnerLayout.astro';
import EquipmentFAQ from '@/components/equipment/EquipmentFAQ.astro';
import { buildFaqPageSchema } from '@/lib/faq-schema';

const faqs = [
  {
    q: '¿Para qué cargas o maniobras conviene rentar una grúa de 15 toneladas en Monterrey?',
    a: 'La grúa de 15 toneladas es adecuada para cargas y maniobras ligeras a medianas: material en obra, apoyo en bodega, maquinaria de menor peso y trabajos donde no hace falta la capacidad de una grúa de 18, 22 o 50 toneladas. Si el peso o el alcance están al límite, te recomendamos evaluar el siguiente tonelaje.',
  },
  {
    q: '¿El operador está incluido en la renta de la grúa de 15 toneladas?',
    a: 'Sí. El servicio de renta incluye operador certificado para maniobra segura. Lo coordinamos directamente con JP Rentals; no necesitas contratar operador por separado.',
  },
  {
    q: '¿Pueden operar la grúa de 15T dentro de una nave industrial o bodega?',
    a: 'Sí, cuando las condiciones de acceso, altura libre y piso lo permiten. Nos comparten fotos o plano del sitio y confirmamos si esta grúa es la adecuada o si conviene una articulada u otra capacidad.',
  },
  {
    q: '¿En qué zona operan con renta de grúa de 15 toneladas?',
    a: 'Nuestro servicio principal cubre Monterrey y el Área Metropolitana (AMM): San Nicolás, Guadalupe, Apodaca, Escobedo, Santa Catarina, San Pedro y zonas industriales aledañas. Para ubicaciones fuera del AMM, consúltanos disponibilidad.',
  },
  {
    q: '¿Cómo pido cotización de renta de grúa de 15 toneladas?',
    a: 'Por WhatsApp al +52 81 1600 7864. Indica peso aproximado de la carga, tipo de maniobra, dirección y fecha tentativa. Te respondemos con disponibilidad y precio.',
  },
];

const schema = buildFaqPageSchema(faqs);
---
<InnerLayout locale="es" title="Renta de Grúa de 15 Toneladas en Monterrey | JP Rentals" description="Renta de grúa convencional de 15 toneladas en Monterrey. Para maniobras ligeras en naves, obra y construcción. Cotiza por WhatsApp." canonical="https://jprentals.mx/equipos/grua-15-toneladas" altHref="https://jprentals.mx/en/equipment/15-ton-crane" altLocale="en" schema={schema}>
  <span slot="breadcrumb"><a href="/servicios/renta-gruas-industriales" class="hover:text-white/80">Renta de grúas industriales</a> / Grúa 15T</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">Renta de Grúa Convencional <span class="text-blue-300">15 Toneladas</span><br/><span class="text-white/80">en Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Renta de grúa ágil y versátil para maniobras de menor tonelaje en naves industriales, proyectos de construcción y obras civiles en Monterrey.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 mb-16 items-center">
        <div class="inner-fade rounded-2xl overflow-hidden aspect-[4/3] bg-brand-100">
          <img src="/images/grua-15t.webp" alt="Renta de grúa convencional 15 toneladas JP Rentals Monterrey" width="600" height="450" class="w-full h-full object-cover" loading="eager" />
        </div>
        <div class="inner-fade">
          <h2 class="text-xl font-bold mb-4">Especificaciones</h2>
          <dl class="space-y-3">
            {[['Capacidad máxima','15 toneladas'],['Tipo','Grúa convencional'],['Disponibilidad','Renta diaria, semanal, mensual'],['Área de operación','Monterrey y área metropolitana'],['Operador','Incluido en el servicio'],['Empresa','JP Rentals — Grupo NASA']].map(([k,v]) => (
              <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">{k}</dt><dd class="text-sm font-semibold">{v}</dd></div>
            ))}
          </dl>
        </div>
      </div>
      <h2 class="text-2xl font-extrabold mb-6 inner-fade">Usos principales</h2>
      <div class="grid md:grid-cols-2 gap-4 mb-16">
        {['Maniobras ligeras en nave industrial','Apoyo en proyectos de construcción','Carga y descarga de equipos menores','Reubicación de maquinaria pequeña','Trabajos en altura con cargas ligeras','Operaciones de apoyo en obra civil'].map(u => (
          <div class="inner-fade flex items-start gap-3 p-4 bg-brand-50 border border-brand-200 rounded-xl">
            <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-medium">{u}</span>
          </div>
        ))}
      </div>
      <EquipmentFAQ
        title="Preguntas frecuentes — grúa de 15 toneladas en Monterrey"
        faqs={faqs}
      />
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Otras grúas disponibles</p>
        <div class="flex flex-wrap gap-3">
          {[['Grúa 50T','/equipos/grua-50-toneladas'],['Grúa 22T','/equipos/grua-22-toneladas'],['Grúa 18T','/equipos/grua-18-toneladas'],['Grúa articulada 8T','/equipos/grua-articulada-8-toneladas']].map(([l,h]) => (
            <a href={h} class="text-sm font-medium text-accent hover:underline">→ {l}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
