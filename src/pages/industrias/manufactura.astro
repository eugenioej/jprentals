---
import InnerLayout from '@/layouts/InnerLayout.astro';
---
<InnerLayout locale="es" title="Grúas para Manufactura en Monterrey | JP Rentals" description="Renta de grúas industriales para plantas de manufactura en Monterrey. Maquinaria CNC, líneas de producción, maquilas y plantas automotrices. Parte de Grupo NASA. Cotiza ya." canonical="https://jprentals.mx/industrias/manufactura" altHref="https://jprentals.mx/en/industries/manufacturing" altLocale="en">
  <span slot="breadcrumb">Industrias / Manufactura</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">Grúas para la Industria<br/><span class="text-blue-300">Manufacturera</span><br/><span class="text-white/80">en Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Movemos maquinaria CNC, líneas de producción, equipos de inyección y todo tipo de maquinaria pesada en plantas de manufactura y maquilas en toda el área metropolitana de Monterrey.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <h2 class="text-2xl font-extrabold mb-3 inner-fade">Soluciones para plantas de manufactura</h2>
      <p class="text-brand-600 mb-10 inner-fade">Monterrey es uno de los centros manufactureros más importantes de México. JP Rentals atiende a plantas de manufactura de todos los tamaños con grúas industriales y fletes especializados.</p>
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        {[
          { t: 'Instalación de líneas de producción', d: 'Posicionamos maquinaria nueva en tu planta: centros de maquinado, prensas, robots, líneas de ensamble. Con la grúa adecuada al peso de cada equipo.' },
          { t: 'Reubicación de maquinaria', d: 'Movemos equipos dentro de la misma planta para reorganizar layouts de producción, ampliar naves o liberar espacio.' },
          { t: 'Cambio de maquinaria', d: 'Retiramos equipos obsoletos e instalamos los nuevos. Coordinamos el tiempo de paro para minimizar el impacto en tu producción.' },
          { t: 'Descarga de maquinaria importada', d: 'Cuando llega tu maquinaria en contenedor o trailer de importación, la descargamos y posicionamos en la línea de producción.' },
          { t: 'Grúa residente en planta', d: 'Si tu planta tiene operaciones continuas de izaje, posicionamos una grúa en tu instalación por días, semanas o meses.' },
          { t: 'Transporte de equipos entre plantas', d: 'Flete local entre plantas de la misma empresa o proveedor dentro del área metropolitana, con carga y descarga incluida.' },
        ].map(item => (
          <div class="inner-fade bg-brand-50 border border-brand-200 rounded-xl p-6">
            <h3 class="font-bold mb-2">{item.t}</h3>
            <p class="text-sm text-brand-600 leading-relaxed">{item.d}</p>
          </div>
        ))}
      </div>
      <h2 class="text-2xl font-extrabold mb-6 inner-fade">Tipos de maquinaria que manejamos</h2>
      <div class="grid sm:grid-cols-3 gap-3 mb-16">
        {['Maquinaria CNC','Centros de maquinado','Prensas hidráulicas','Robots industriales','Equipos de inyección','Compresores y bombas','Transformadores','Generadores','Equipos de proceso','Hornos y calentadores','Maquinaria textil','Equipos de soldadura'].map(m => (
          <div class="inner-fade text-sm px-4 py-3 bg-white border border-brand-200 rounded-lg text-center font-medium">{m}</div>
        ))}
      </div>
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Grúas disponibles para manufactura</p>
        <div class="flex flex-wrap gap-3">
          {[['Renta de grúas industriales','/servicios/renta-gruas-industriales'],['Maniobras industriales','/servicios/maniobras-industriales'],['Flete local con tráiler','/servicios/flete-local-trailer'],['Grúas para construcción','/industrias/construccion']].map(([l,h]) => (
            <a href={h} class="text-sm font-medium text-accent hover:underline">→ {l}</a>
          ))}
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
