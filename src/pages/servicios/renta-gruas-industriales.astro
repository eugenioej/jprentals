---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { waLink } from '@/i18n/utils';

const wa = waLink('Hola JP Rentals, me interesa la renta de grúas industriales. ¿Me pueden cotizar capacidad y disponibilidad?');
const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Renta de Grúas Industriales en Monterrey",
  "provider": { "@type": "LocalBusiness", "name": "JP Rentals", "url": "https://jprentals.mx", "telephone": "+528116007864" },
  "areaServed": { "@type": "City", "name": "Monterrey" },
  "description": "Renta de grúas industriales de 8 a 50 toneladas para maniobras en planta, obra y construcción en Monterrey y área metropolitana.",
  "serviceType": "Industrial Crane Rental"
};
---

<InnerLayout
  locale="es"
  title="Renta de Grúas Industriales en Monterrey | JP Rentals"
  description="Renta de grúas industriales de 8 a 50 toneladas para maniobras en planta, obra y proyectos de construcción. Flota disponible en Monterrey y área metropolitana. Cotiza por WhatsApp."
  canonical="https://jprentals.mx/servicios/renta-gruas-industriales"
  altHref="https://jprentals.mx/en/services/industrial-crane-rental"
  altLocale="en"
  schema={schema}
>
  <span slot="breadcrumb">Renta de Grúas Industriales</span>

  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">
      Renta de Grúas Industriales<br />
      <span class="text-white/80">en Monterrey</span>
    </h1>
    <p class="text-lg text-white/90 max-w-2xl">
      Grúas de 8 a 50 toneladas para maniobras en planta, montajes pesados y proyectos de construcción. Parte de Grupo NASA, con más de 30 años en la industria.
    </p>
  </div>

  <!-- Capacidades -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-extrabold mb-3 inner-fade">Capacidades disponibles</h2>
        <p class="text-brand-600 mb-10 inner-fade">Toda la flota disponible para renta diaria, semanal o mensual en Monterrey y área metropolitana.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
          {[
            { cap: '50 Toneladas', tipo: 'Grúa convencional', uso: 'Maniobras de gran escala, montajes pesados y estructuras industriales.', href: '/equipos/grua-50-toneladas', img: '/images/grua-50t.webp' },
            { cap: '22 Toneladas', tipo: 'Grúa convencional', uso: 'Proyectos industriales medianos, traslado de maquinaria y equipos.', href: '/equipos/grua-22-toneladas', img: '/images/grua-22t.webp' },
            { cap: '18 Toneladas', tipo: 'Grúa convencional', uso: 'Maniobras en planta, carga y descarga de equipos industriales.', href: '/equipos/grua-18-toneladas', img: '/images/grua-18t.webp' },
            { cap: '15 Toneladas', tipo: 'Grúa convencional', uso: 'Maniobras ligeras en naves y proyectos de construcción.', href: '/equipos/grua-15-toneladas', img: '/images/grua-15t.webp' },
            { cap: '8 Toneladas', tipo: 'Grúa articulada', uso: 'Carga y descarga, espacios reducidos y accesos difíciles.', href: '/equipos/grua-articulada-8-toneladas', img: '/images/grua-articulada-8t.webp' },
          ].map(item => (
            <a href={item.href} class="inner-fade group bg-white border border-brand-200 rounded-xl overflow-hidden hover:border-brand-400 hover:shadow-md transition-all">
              <div class="aspect-[4/3] overflow-hidden bg-brand-100">
                <img src={item.img} alt={`${item.tipo} ${item.cap} JP Rentals`} width="400" height="300" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-bold text-brand-600 uppercase tracking-wider">{item.tipo}</span>
                  <span class="text-xs font-bold bg-accent/10 text-accent px-2 py-0.5 rounded">{item.cap}</span>
                </div>
                <p class="text-sm text-brand-600">{item.uso}</p>
              </div>
            </a>
          ))}
        </div>

        <!-- Features -->
        <div class="grid md:grid-cols-2 gap-8 mb-16">
          <div class="inner-fade">
            <h3 class="text-xl font-bold mb-4">¿Para qué tipo de proyectos?</h3>
            <ul class="space-y-3 text-brand-600">
              {['Montaje y desmontaje de maquinaria industrial', 'Instalación de estructuras metálicas', 'Proyectos de construcción y obra civil', 'Carga y descarga en puertos y andenes', 'Posicionamiento de equipos en plantas', 'Trabajos en espacios reducidos o con acceso difícil'].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="inner-fade">
            <h3 class="text-xl font-bold mb-4">¿Por qué rentar con JP Rentals?</h3>
            <ul class="space-y-3 text-brand-600">
              {['Más de 30 años en la industria pesada en Monterrey', 'Parte de Grupo NASA — empresa consolidada', 'Operadores con experiencia en maniobras industriales', 'Flota propia, sin intermediarios', 'Atención directa por WhatsApp', 'Cobertura en toda el área metropolitana de Monterrey'].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- How it works -->
        <h3 class="text-xl font-bold mb-6 inner-fade">¿Cómo funciona?</h3>
        <div class="grid md:grid-cols-3 gap-6 mb-16">
          {[
            { n: '1', t: 'Cotiza por WhatsApp', d: 'Envíanos el peso de la carga, el tipo de maniobra y la ubicación. Respondemos con precio y disponibilidad.' },
            { n: '2', t: 'Confirmamos y coordinamos', d: 'Agendamos la fecha, confirmamos la grúa adecuada y coordinamos el acceso al sitio.' },
            { n: '3', t: 'Ejecutamos la maniobra', d: 'Nuestro operador llega puntual, ejecuta la maniobra con seguridad y confirmamos el trabajo completado.' },
          ].map(step => (
            <div class="inner-fade flex gap-4">
              <span class="w-9 h-9 rounded-full bg-accent text-white text-sm font-bold flex items-center justify-center shrink-0">{step.n}</span>
              <div>
                <h4 class="font-bold mb-1">{step.t}</h4>
                <p class="text-sm text-brand-600">{step.d}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- FAQ -->
        <h3 class="text-xl font-bold mb-6 inner-fade">Preguntas frecuentes</h3>
        <div class="space-y-4 mb-8">
          {[
            { q: '¿Cuánto cuesta rentar una grúa industrial en Monterrey?', a: 'El precio varía según la capacidad de la grúa, el tipo de maniobra, la duración y la ubicación. Escríbenos por WhatsApp con los detalles de tu proyecto y te damos precio exacto.' },
            { q: '¿Incluyen operador en la renta?', a: 'Sí. Todas nuestras grúas se rentan con operador. El operador lleva la experiencia necesaria para ejecutar la maniobra con seguridad en tu planta u obra.' },
            { q: '¿Cubren toda el área metropolitana de Monterrey?', a: 'Sí. Operamos en Monterrey, San Pedro, Santa Catarina, Guadalupe, Apodaca, General Escobedo, San Nicolás y zonas industriales aledañas.' },
            { q: '¿Qué grúa necesito para mi proyecto?', a: 'Depende del peso de la carga y el tipo de maniobra. Tenemos grúas de 8 hasta 50 toneladas. Cuéntanos tu necesidad y te recomendamos el equipo correcto.' },
          ].map(faq => (
            <details class="inner-fade border border-brand-200 rounded-xl p-5 group">
              <summary class="font-semibold cursor-pointer list-none flex items-center justify-between gap-4">
                {faq.q}
                <svg class="w-4 h-4 text-brand-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-3 text-brand-600 text-sm leading-relaxed">{faq.a}</p>
            </details>
          ))}
        </div>

        <!-- Internal links -->
        <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
          <p class="text-sm font-semibold text-brand-600 mb-3">Otros servicios que pueden interesarte</p>
          <div class="flex flex-wrap gap-3">
            <a href="/servicios/flete-local-trailer" class="text-sm font-medium text-accent hover:underline">→ Flete local con tráiler</a>
            <a href="/servicios/maniobras-industriales" class="text-sm font-medium text-accent hover:underline">→ Maniobras industriales</a>
            <a href="/industrias/manufactura" class="text-sm font-medium text-accent hover:underline">→ Grúas para manufactura</a>
            <a href="/industrias/construccion" class="text-sm font-medium text-accent hover:underline">→ Grúas para construcción</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
