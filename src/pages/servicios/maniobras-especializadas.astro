---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { waLink } from '@/i18n/utils';

const waPrimary = waLink(
  'Hola JP Rentals, necesito una cotización para maniobras industriales en Monterrey. ¿Me pueden atender el mismo día?'
);
const waClosing = waLink(
  'Hola JP Rentals, tengo una maniobra programada (o una emergencia operativa) y necesito cotización. ¿Me pueden ayudar?'
);

const serviceSchema = {
  '@type': 'Service',
  name: 'Maniobras industriales especializadas en Monterrey',
  description:
    'Izaje, rigging e instalación de maquinaria pesada en planta y obra. Monterrey y AMM. Respuesta el mismo día por WhatsApp.',
  provider: { '@type': 'LocalBusiness', name: 'JP Rentals', url: 'https://jprentals.mx', telephone: '+528116007864' },
  areaServed: { '@type': 'City', name: 'Monterrey' },
  serviceType: 'Industrial Rigging and Heavy Machinery Installation',
};

const faqEntities = [
  {
    '@type': 'Question',
    name: '¿En cuánto tiempo pueden responder a una solicitud?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Normalmente cotizamos el mismo día por WhatsApp. La disponibilidad de equipo y el arranque del servicio dependen del tipo de maniobra, pero en la mayoría de los casos podemos confirmar operación en menos de 24 horas.',
    },
  },
  {
    '@type': 'Question',
    name: '¿Qué capacidades de izaje manejan?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Nuestra flota cubre desde 8 hasta 50 toneladas. Si necesitas capacidades mayores o una configuración específica, contáctanos — evaluamos cada caso.',
    },
  },
  {
    '@type': 'Question',
    name: '¿Operan dentro de plantas en producción?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Sí. Tenemos experiencia trabajando en instalaciones activas con restricciones de seguridad, espacio y tiempo. Coordinamos con el equipo de mantenimiento o seguridad industrial de tu planta antes de iniciar.',
    },
  },
  {
    '@type': 'Question',
    name: '¿Solo operan en Monterrey?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Nuestro servicio principal cubre Monterrey y el Área Metropolitana de Nuevo León. Para proyectos fuera del AMM, consúltanos directamente.',
    },
  },
  {
    '@type': 'Question',
    name: '¿Cómo solicito una cotización?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Por WhatsApp al +52 81 1600 7864. Comparte el tipo de maniobra, las dimensiones o peso aproximado del equipo y la ubicación — y te respondemos con disponibilidad y costo.',
    },
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    serviceSchema,
    {
      '@type': 'FAQPage',
      mainEntity: faqEntities,
    },
  ],
};
---

<InnerLayout
  locale="es"
  title="Maniobras industriales especializadas en Monterrey | Mismo día | JP Rentals"
  description="Maniobras industriales en Monterrey: izaje, rigging e instalación de maquinaria pesada en planta y obra. Flota en el AMM. Cotización por WhatsApp el mismo día. Grupo NASA."
  canonical="https://jprentals.mx/servicios/maniobras-especializadas"
  altHref="https://jprentals.mx/en/services/industrial-rigging"
  altLocale="en"
  schema={schema}
>
  <span slot="breadcrumb">
    <a href="/servicios/maniobras-industriales" class="hover:text-white/80 transition-colors">Maniobras industriales</a>
    <span> / </span>
    <span class="text-white/70">Especializadas</span>
  </span>

  <div slot="hero">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight mb-4">
      Maniobras industriales en Monterrey — respondemos el mismo día
    </h1>
    <p class="text-lg text-white/90 max-w-2xl mb-2">
      Izaje, rigging e instalación de maquinaria pesada en planta y obra.
    </p>
    <p class="text-lg text-white/85 max-w-2xl mb-8">
      Flota disponible en el AMM. Cotización por WhatsApp en minutos.
    </p>
    <div class="flex flex-col sm:flex-row flex-wrap gap-4">
      <a
        href={waPrimary}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#1fb855] transition-colors text-base"
      >
        → Cotizar por WhatsApp
      </a>
      <a
        href="/servicios/renta-gruas-industriales"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-base"
      >
        Ver flota de grúas
      </a>
    </div>
  </div>

  <!-- Sección 1 -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-6 inner-fade leading-tight">
        Cada hora parada en planta tiene un costo. Nosotros lo entendemos.
      </h2>
      <div class="space-y-5 text-brand-600 leading-relaxed inner-fade">
        <p>
          Cuando necesitas mover, instalar o reubicar maquinaria pesada, el tiempo de respuesta no es un detalle — es la diferencia entre un paro programado y un paro que se extiende. JP Rentals opera en Monterrey y área metropolitana con disponibilidad real: flota propia, operadores especializados y confirmación de servicio el mismo día que contactas.
        </p>
        <p>
          No manejamos listas de espera de una semana. Si el equipo está disponible, salimos.
        </p>
      </div>
    </div>
  </section>

  <!-- Sección 2 -->
  <section class="py-16 md:py-24 bg-brand-50 border-y border-brand-100">
    <div class="container max-w-5xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 text-center inner-fade">
        ¿Qué tipo de maniobra necesitas?
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Izaje de maquinaria en planta</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Instalación, reubicación o retiro de equipos industriales dentro de nave. Trabajamos con líneas de producción activas, coordinando la maniobra para minimizar el tiempo fuera de operación.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Rigging industrial</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Planeación y ejecución de maniobras complejas: cálculo de cargas, selección de eslingado, coordinación de puntos de izaje. Para equipos que no admiten error de cálculo.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Maniobras en obra y construcción</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Montaje de estructuras, colocación de elementos prefabricados y manejo de cargas en espacios con acceso restringido. Grúas desde 8 hasta 50 toneladas según lo que requiera el proyecto.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Traslado con maniobra incluida</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Transportamos tu maquinaria dentro del AMM y la instalamos en el punto exacto. Un solo proveedor para el flete y la maniobra — sin coordinación entre terceros.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección 3 -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-6 inner-fade leading-tight">
        Disponibilidad no es una promesa de marketing. Es lo que nos define.
      </h2>
      <div class="space-y-5 text-brand-600 leading-relaxed inner-fade">
        <p>
          Operamos con flota propia en Monterrey. No somos intermediarios que subcontratan el equipo — cuando llamas, sabemos qué grúa está disponible y cuándo puede estar en tu ubicación. Eso se traduce en una cosa concreta:{' '}
          <strong class="text-brand-900">respuesta el mismo día y arranque en 24 horas en la mayoría de los casos.</strong>
        </p>
        <p>
          Somos parte de Grupo NASA, con presencia industrial en el noreste de México. Eso nos da respaldo operativo real y experiencia acumulada en manufactura, obra industrial y proyectos de alta exigencia.
        </p>
      </div>
    </div>
  </section>

  <!-- Sección 4 -->
  <section class="py-16 md:py-24 bg-brand-50 border-y border-brand-100">
    <div class="container max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 text-center inner-fade">
        Trabajamos donde la maniobra no puede fallar
      </h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-8">
          <h3 class="text-xl font-bold text-brand-900 mb-4">Manufactura</h3>
          <p class="text-brand-600 leading-relaxed">
            Plantas de autopartes, alimentos, metal-mecánica y logística en parques industriales del AMM. Sabemos operar con protocolos de seguridad internos y tiempos de paro acotados.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-8">
          <h3 class="text-xl font-bold text-brand-900 mb-4">Construcción industrial</h3>
          <p class="text-brand-600 leading-relaxed">
            Estructuras, naves, subestaciones y obra pesada. Coordinamos con superintendentes de obra para que la maniobra encaje en el programa de construcción, no al revés.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 inner-fade text-center md:text-left">
        Preguntas frecuentes sobre maniobras industriales en Monterrey
      </h2>
      <div class="space-y-4">
        {faqEntities.map((faq) => (
          <details class="inner-fade border border-brand-200 rounded-xl p-5 group bg-brand-50/50">
            <summary class="font-semibold cursor-pointer list-none flex items-center justify-between gap-4 text-brand-900">
              {faq.name}
              <svg class="w-4 h-4 text-brand-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-brand-600 text-sm leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Cierre -->
  <section class="py-16 md:py-24 bg-brand-black text-white">
    <div class="container max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-6 inner-fade leading-tight">
        ¿Tienes una maniobra programada o una emergencia operativa?
      </h2>
      <p class="text-white/85 mb-4 inner-fade leading-relaxed">
        Cuéntanos qué necesitas. Sin formularios largos, sin semanas de espera.
      </p>
      <p class="text-white/80 mb-10 inner-fade">
        Cotización directa por WhatsApp — respondemos el mismo día.
      </p>
      <div class="inner-fade flex flex-col items-center gap-4">
        <a
          href={waClosing}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#1fb855] transition-colors text-base"
        >
          → Escribir por WhatsApp ahora
        </a>
        <p class="text-sm text-white/60">
          +52 81 1600 7864 · Lunes a sábado 07:00–19:00
        </p>
      </div>
    </div>
  </section>
</InnerLayout>
