---
import InnerLayout from '@/layouts/InnerLayout.astro';
import EquipmentFAQ from '@/components/equipment/EquipmentFAQ.astro';
import { buildFaqPageSchema } from '@/lib/faq-schema';

const faqs = [
  {
    q: 'What industrial projects use a 22-ton crane?',
    a: 'Mid-size manufacturing: CNC centers, presses, process equipment, transformers, and plant machinery that exceeds 15–18T capacity but does not yet require a 50-ton crane. Also common for mid-weight industrial construction lifts.',
  },
  {
    q: 'Does 22-ton crane rental in Monterrey include an operator?',
    a: 'Yes. A certified operator is included with every JP Rentals crane rental with operation.',
  },
  {
    q: 'Can you move heavy machinery between bays inside the same plant?',
    a: 'Yes, when the travel path is feasible—we review aisle width, doors, and obstructions. We pick the right crane and lift plan for the weight and geometry.',
  },
  {
    q: 'Do you only work in Monterrey and the AMM?',
    a: 'Our core service is Greater Monterrey. For sites outside the metropolitan area, ask about availability and equipment mobilization cost.',
  },
  {
    q: 'What information do you need to quote a 22-ton crane rental?',
    a: 'Approximate weight and dimensions, origin/destination of the lift if applicable, address, and preferred timing. Quote via WhatsApp +52 81 1600 7864.',
  },
];

const schema = buildFaqPageSchema(faqs);
---
<InnerLayout locale="en" title="22-Ton Crane Rental in Monterrey | JP Rentals" description="Crane rental in Monterrey: 22-ton conventional crane for mid-size industrial projects and CNC machinery moves. Operator included. JP Rentals — Grupo NASA. Quote via WhatsApp." canonical="https://jprentals.mx/en/equipment/22-ton-crane" altHref="https://jprentals.mx/equipos/grua-22-toneladas" altLocale="es" schema={schema}>
  <span slot="breadcrumb"><a href="/en/services/industrial-crane-rental" class="hover:text-white/80">Industrial crane rental</a> / 22T Crane</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">22-Ton Crane Rental<br/><span class="text-white/80">in Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Crane rental with 22-ton capacity for mid-size industrial projects and CNC machinery moves. Operator included. Daily, weekly, or monthly rental across the Monterrey metro area.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 mb-16 items-center">
        <div class="inner-fade rounded-2xl overflow-hidden aspect-[4/3] bg-brand-100">
          <img src="/images/grua-22t.webp" alt="22T crane JP Rentals Monterrey" width="600" height="450" class="w-full h-full object-cover" loading="eager" />
        </div>
        <div class="inner-fade">
          <h2 class="text-xl font-bold mb-4">Specifications</h2>
          <dl class="space-y-3">
            <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">Max capacity</dt><dd class="text-sm font-semibold">22 tons</dd></div>
            <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">Availability</dt><dd class="text-sm font-semibold">Daily, weekly, monthly</dd></div>
            <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">Service area</dt><dd class="text-sm font-semibold">Monterrey metro area</dd></div>
            <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">Operator</dt><dd class="text-sm font-semibold">Included</dd></div>
            <div class="flex justify-between py-2 border-b border-brand-100"><dt class="text-sm text-brand-600">Company</dt><dd class="text-sm font-semibold">JP Rentals — Grupo NASA</dd></div>
          </dl>
        </div>
      </div>
      <EquipmentFAQ title="FAQ — 22-ton crane rental in Monterrey" faqs={faqs} />
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Other cranes available</p>
        <div class="flex flex-wrap gap-3">
          <a href="/en/equipment/50-ton-crane" class="text-sm font-medium text-accent hover:underline">→ 50T Crane</a>
          <a href="/en/equipment/22-ton-crane" class="text-sm font-medium text-accent hover:underline">→ 22T Crane</a>
          <a href="/en/equipment/18-ton-crane" class="text-sm font-medium text-accent hover:underline">→ 18T Crane</a>
          <a href="/en/equipment/15-ton-crane" class="text-sm font-medium text-accent hover:underline">→ 15T Crane</a>
          <a href="/en/equipment/8-ton-articulated-crane" class="text-sm font-medium text-accent hover:underline">→ 8T Articulated</a>
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
