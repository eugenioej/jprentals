---
import InnerLayout from '@/layouts/InnerLayout.astro';
---
<InnerLayout locale="en" title="Local Heavy Machinery Freight in Monterrey | JP Rentals" description="Local freight for heavy machinery up to 30 tons in Monterrey. Howo trailer with articulated crane included for door-to-door loading and unloading. Quote via WhatsApp." canonical="https://jprentals.mx/en/services/local-freight" altHref="https://jprentals.mx/servicios/flete-local-trailer" altLocale="es">
  <span slot="breadcrumb">Local Freight with Trailer</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">Local Freight with Trailer<br/><span class="text-white/80">in Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Heavy machinery transport up to 30 tons with loading and unloading included. Howo trailer with articulated crane for complete door-to-door service across the Monterrey metro area.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-6 mb-16">
        {[
          { name: 'Howo Trailer', cap: '30 Tons', img: '/images/trailer-howo.webp', features: ['Articulated crane included','Loading & unloading at destination','Same-day availability','Full metro area coverage'] },
          { name: 'Extendable Platform', cap: '30T / up to 60m', img: '/images/plataforma-extensible.webp', features: ['For oversized loads','Up to 60 meters long','Ideal for beams and structures','Specialized equipment'] },
        ].map(v => (
          <div class="inner-fade bg-white border border-brand-200 rounded-xl overflow-hidden">
            <div class="aspect-[16/9] overflow-hidden bg-brand-100">
              <img src={v.img} alt={`${v.name} JP Rentals freight Monterrey`} width="600" height="338" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <h3 class="font-bold text-lg">{v.name}</h3>
                <span class="text-xs font-bold bg-accent/10 text-accent px-2 py-1 rounded">{v.cap}</span>
              </div>
              <ul class="space-y-2">
                {v.features.map(f => (
                  <li class="flex items-center gap-2 text-sm text-brand-600">
                    <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Related services</p>
        <div class="flex flex-wrap gap-3">
          <a href="/en/services/industrial-crane-rental" class="text-sm font-medium text-accent hover:underline">→ Industrial crane rental</a>
          <a href="/en/services/industrial-rigging" class="text-sm font-medium text-accent hover:underline">→ Industrial rigging</a>
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
