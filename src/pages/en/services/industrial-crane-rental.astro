---
import InnerLayout from '@/layouts/InnerLayout.astro';
---
<InnerLayout locale="en" title="Industrial Crane Rental in Monterrey | JP Rentals" description="Industrial crane rental from 8 to 50 tons in Monterrey. For plant operations, heavy assembly, and construction projects. Part of Grupo NASA. Quote via WhatsApp." canonical="https://jprentals.mx/en/services/industrial-crane-rental" altHref="https://jprentals.mx/servicios/renta-gruas-industriales" altLocale="es">
  <span slot="breadcrumb">Industrial crane rental</span>
  <div slot="hero">
    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight mb-4">Industrial Crane Rental<br/><span class="text-white/80">in Monterrey</span></h1>
    <p class="text-lg text-white/90 max-w-2xl">Crane rental: 8 to 50 tons for industrial rigging, heavy assembly, and construction projects. Part of Grupo NASA — over 30 years serving the heavy industry in Monterrey.</p>
  </div>
  <section class="py-16 md:py-24">
    <div class="container max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-3 inner-fade">Available capacities</h2>
      <p class="text-brand-600 mb-10 inner-fade">Full fleet available for daily, weekly, or monthly rental across the Monterrey metropolitan area.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
        {[
          { cap: '50 Tons', tipo: 'Conventional crane', uso: 'Large-scale industrial rigging and heavy assembly.', href: '/en/equipment/50-ton-crane', img: '/images/grua-50t.webp' },
          { cap: '22 Tons', tipo: 'Conventional crane', uso: 'Mid-size industrial projects and machinery moves.', href: '/en/equipment/22-ton-crane', img: '/images/grua-22t.webp' },
          { cap: '18 Tons', tipo: 'Conventional crane', uso: 'Plant operations, loading and unloading.', href: '/en/equipment/18-ton-crane', img: '/images/grua-18t.webp' },
          { cap: '15 Tons', tipo: 'Conventional crane', uso: 'Light rigging in warehouses and construction.', href: '/en/equipment/15-ton-crane', img: '/images/grua-15t.webp' },
          { cap: '8 Tons', tipo: 'Articulated crane', uso: 'Loading/unloading and tight-access jobs.', href: '/en/equipment/8-ton-articulated-crane', img: '/images/grua-articulada-8t.webp' },
        ].map(item => (
          <a href={item.href} class="inner-fade group bg-white border border-brand-200 rounded-xl overflow-hidden hover:border-brand-400 hover:shadow-md transition-all">
            <div class="aspect-[4/3] overflow-hidden bg-brand-100">
              <img src={item.img} alt={`${item.tipo} ${item.cap} JP Rentals`} width="400" height="300" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-bold text-brand-600 uppercase tracking-wider">{item.tipo}</span>
                <span class="text-xs font-bold bg-accent/10 text-accent px-2 py-0.5 rounded">{item.cap}</span>
              </div>
              <p class="text-sm text-brand-600">{item.uso}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="inner-fade">
          <h3 class="text-xl font-bold mb-4">Typical applications</h3>
          <ul class="space-y-3 text-brand-600">
            {['Machinery installation and removal','Steel structure erection','Heavy equipment positioning','Loading and unloading operations','Plant reorganization and relocation','Monthly crane placement at your facility'].map(i => (
              <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>{i}</li>
            ))}
          </ul>
        </div>
        <div class="inner-fade">
          <h3 class="text-xl font-bold mb-4">Why JP Rentals?</h3>
          <ul class="space-y-3 text-brand-600">
            {['30+ years in Monterrey heavy industry','Part of Grupo NASA — established group','Experienced operators included','Own fleet, no intermediaries','Direct WhatsApp quoting','Full metro area coverage'].map(i => (
              <li class="flex items-start gap-2 text-sm"><svg class="w-4 h-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>{i}</li>
            ))}
          </ul>
        </div>
      </div>
      <div class="inner-fade bg-brand-50 border border-brand-200 rounded-2xl p-6">
        <p class="text-sm font-semibold text-brand-600 mb-3">Related services</p>
        <div class="flex flex-wrap gap-3">
          <a href="/en/services/local-freight" class="text-sm font-medium text-accent hover:underline">→ Local freight with trailer</a>
          <a href="/en/services/industrial-rigging" class="text-sm font-medium text-accent hover:underline">→ Industrial rigging</a>
          <a href="/en/industries/manufacturing" class="text-sm font-medium text-accent hover:underline">→ Cranes for manufacturing</a>
        </div>
      </div>
    </div>
  </section>
</InnerLayout>
