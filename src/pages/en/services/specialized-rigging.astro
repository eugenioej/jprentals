---
import InnerLayout from '@/layouts/InnerLayout.astro';
import { waLink } from '@/i18n/utils';

const waPrimary = waLink(
  'Hello JP Rentals, I need a quote for industrial rigging in Monterrey. Can you respond the same day?'
);

const serviceSchema = {
  '@type': 'Service',
  name: 'Same-day specialized industrial rigging in Monterrey',
  description:
    'Lifting, rigging, and heavy machinery installation in plant and on site. Monterrey metro area. Same-day response via WhatsApp.',
  provider: { '@type': 'LocalBusiness', name: 'JP Rentals', url: 'https://jprentals.mx', telephone: '+528116007864' },
  areaServed: { '@type': 'City', name: 'Monterrey' },
  serviceType: 'Industrial Rigging and Heavy Machinery Installation',
};

const faqEntities = [
  {
    '@type': 'Question',
    name: 'How fast can you respond to a request?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'We usually quote the same day on WhatsApp. Equipment availability and job start depend on the type of lift, but in most cases we can confirm service in under 24 hours.',
    },
  },
  {
    '@type': 'Question',
    name: 'What lifting capacities do you offer?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Our fleet covers 8 through 50 tons. If you need higher capacity or a specific configuration, contact us—we evaluate each case.',
    },
  },
  {
    '@type': 'Question',
    name: 'Do you work inside plants that are still in production?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Yes. We routinely work in active facilities with safety, space, and time constraints. We coordinate with your maintenance or industrial safety team before we start.',
    },
  },
  {
    '@type': 'Question',
    name: 'Do you only work in Monterrey?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'Our core coverage is Monterrey and the Greater Monterrey metropolitan area (AMM). For projects outside the AMM, contact us directly.',
    },
  },
  {
    '@type': 'Question',
    name: 'How do I request a quote?',
    acceptedAnswer: {
      '@type': 'Answer',
      text: 'WhatsApp +52 81 1600 7864. Share the type of lift, approximate equipment dimensions or weight, and location—we respond with availability and pricing.',
    },
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    serviceSchema,
    {
      '@type': 'FAQPage',
      mainEntity: faqEntities,
    },
  ],
};
---

<InnerLayout
  locale="en"
  title="Same-Day Specialized Industrial Rigging in Monterrey | JP Rentals"
  description="Industrial rigging in Monterrey: lifting, rigging, and heavy machinery installation in plant and on site. Fleet in the metro area. WhatsApp quotes the same day. Grupo NASA."
  canonical="https://jprentals.mx/en/services/specialized-rigging"
  altHref="https://jprentals.mx/servicios/maniobras-especializadas"
  altLocale="es"
  schema={schema}
>
  <span slot="breadcrumb">
    <a href="/en/services/industrial-rigging" class="hover:text-white/80 transition-colors">Industrial rigging</a>
    <span> / </span>
    <span class="text-white/70">Same-day</span>
  </span>

  <div slot="hero">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight mb-4">
      Industrial rigging in Monterrey — we respond the same day
    </h1>
    <p class="text-lg text-white/90 max-w-2xl mb-2">
      Lifting, rigging, and installation of heavy machinery in plant and on construction sites.
    </p>
    <p class="text-lg text-white/85 max-w-2xl mb-8">
      Fleet available across the metro area. Quotes on WhatsApp in minutes.
    </p>
    <div class="flex flex-col sm:flex-row flex-wrap gap-4">
      <a
        href={waPrimary}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#1fb855] transition-colors text-base"
      >
        → Get a quote on WhatsApp
      </a>
      <a
        href="/en/services/industrial-crane-rental"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-base"
      >
        View crane fleet
      </a>
    </div>
  </div>

  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-6 inner-fade leading-tight">
        Every hour down in your plant has a cost. We get that.
      </h2>
      <div class="space-y-5 text-brand-600 leading-relaxed inner-fade">
        <p>
          When you need to move, install, or relocate heavy machinery, response time is not a minor detail — it is the difference between a planned shutdown and one that drags on. JP Rentals operates in Monterrey and the metropolitan area with real availability: owned fleet, specialized operators, and service confirmation the same day you reach out.
        </p>
        <p>We do not run one-week waitlists. If the equipment is available, we roll.</p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-brand-50 border-y border-brand-100">
    <div class="container max-w-5xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 text-center inner-fade">What type of lift do you need?</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">In-plant machinery lifting</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Installation, relocation, or removal of industrial equipment inside your building. We work with active production lines and coordinate the lift to minimize downtime.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Industrial rigging</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Planning and execution of complex lifts: load calculations, rigging selection, lift-point coordination — for equipment where guesswork is not an option.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Construction-site lifts</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            Steel erection, placement of precast elements, and handling loads in tight-access areas. Cranes from 8 to 50 tons depending on project requirements.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-6 md:p-8">
          <h3 class="text-lg font-bold text-brand-900 mb-3">Transport with rigging included</h3>
          <p class="text-sm text-brand-600 leading-relaxed">
            We move your machinery within the AMM and set it in place. One provider for freight and rigging — no juggling multiple vendors.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-6 inner-fade leading-tight">
        Availability is not a marketing line. It defines us.
      </h2>
      <div class="space-y-5 text-brand-600 leading-relaxed inner-fade">
        <p>
          We run our own fleet in Monterrey. We are not a broker that subcontracts blind — when you call, we know which crane is available and when it can be on your site. That means{' '}
          <strong class="text-brand-900">same-day response and mobilization within 24 hours in most cases.</strong>
        </p>
        <p>
          We are part of Grupo NASA, with industrial presence across northeastern Mexico. That gives us real operational backing and deep experience in manufacturing, industrial construction, and high-demand projects.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-brand-50 border-y border-brand-100">
    <div class="container max-w-4xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 text-center inner-fade">We work where the lift cannot fail</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-8">
          <h3 class="text-xl font-bold text-brand-900 mb-4">Manufacturing</h3>
          <p class="text-brand-600 leading-relaxed">
            Automotive suppliers, food, metal fabrication, and logistics in industrial parks across the AMM. We operate under your internal safety protocols and tight shutdown windows.
          </p>
        </div>
        <div class="inner-fade bg-white border border-brand-200 rounded-xl p-8">
          <h3 class="text-xl font-bold text-brand-900 mb-4">Industrial construction</h3>
          <p class="text-brand-600 leading-relaxed">
            Steel buildings, substations, and heavy civil-industrial work. We align with site superintendents so the lift fits the schedule — not the other way around.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="container max-w-3xl mx-auto px-4">
      <h2 class="text-2xl md:text-3xl font-extrabold text-brand-900 mb-10 inner-fade text-center md:text-left">
        FAQ — industrial rigging in Monterrey
      </h2>
      <div class="space-y-4">
        {faqEntities.map((faq) => (
          <details class="inner-fade border border-brand-200 rounded-xl p-5 group bg-brand-50/50">
            <summary class="font-semibold cursor-pointer list-none flex items-center justify-between gap-4 text-brand-900">
              {faq.name}
              <svg class="w-4 h-4 text-brand-400 shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-3 text-brand-600 text-sm leading-relaxed">{faq.acceptedAnswer.text}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</InnerLayout>
